---
// PUBLIC PAGE - NO AUTH REQUIRED
import '../styles/globals.css';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Spirit Media - Client Guide</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;600;700&display=swap" rel="stylesheet" />
  </head>

  <body class="bg-navy text-white">
    <div class="min-h-screen">
      <!-- Header -->
      <header class="border-b border-gold border-opacity-20 bg-navy bg-opacity-50 backdrop-blur">
        <div class="max-w-4xl mx-auto px-6 py-8">
          <h1 class="text-4xl font-bold">
            <span>Spirit</span>
            <span class="text-gold">Media</span>
          </h1>
          <p class="text-gray-400 mt-2">Client Content Management Guide</p>
        </div>
      </header>

      <!-- Main Content -->
      <main class="max-w-4xl mx-auto px-6 py-12">
        <section class="space-y-8">
          <!-- Welcome -->
          <div class="bg-white bg-opacity-5 border border-gold border-opacity-20 rounded-lg p-8">
            <h2 class="text-3xl font-bold text-gold mb-4">Welcome!</h2>
            <p class="text-gray-300 text-lg">
              You're part of the Spirit Media family. Managing your website content is easy and intuitive using Sanity CMS. This guide will walk you through the essentials.
            </p>
          </div>

          <!-- Getting Started -->
          <section class="space-y-4">
            <h2 class="text-3xl font-bold text-gold">Getting Started</h2>

            <div class="bg-white bg-opacity-5 border border-gold border-opacity-20 rounded-lg p-6">
              <h3 class="text-xl font-bold text-gold mb-3">Step 1: Access Your Sanity Studio</h3>
              <p class="text-gray-300 mb-4">
                Your content management dashboard is hosted at your Sanity studio URL. Here's how to access it:
              </p>
              <ol class="list-decimal list-inside space-y-2 text-gray-300 ml-2">
                <li>Visit your Sanity studio link (provided by Spirit Media)</li>
                <li>Sign in with your Sanity credentials</li>
                <li>You'll see your content dashboard</li>
              </ol>
            </div>

            <div class="bg-white bg-opacity-5 border border-gold border-opacity-20 rounded-lg p-6">
              <h3 class="text-xl font-bold text-gold mb-3">Step 2: Edit Your Content</h3>
              <p class="text-gray-300 mb-4">
                Sanity makes content editing simple:
              </p>
              <ul class="space-y-2 text-gray-300 ml-4">
                <li>✓ Click on any content type in the sidebar</li>
                <li>✓ Select the item you want to edit</li>
                <li>✓ Make changes directly in the editor</li>
                <li>✓ Add images, videos, and rich text formatting</li>
                <li>✓ Preview changes in real-time</li>
              </ul>
            </div>

            <div class="bg-white bg-opacity-5 border border-gold border-opacity-20 rounded-lg p-6">
              <h3 class="text-xl font-bold text-gold mb-3">Step 3: Publish Your Changes</h3>
              <p class="text-gray-300 mb-4">
                Once you're happy with your changes:
              </p>
              <ol class="list-decimal list-inside space-y-2 text-gray-300 ml-2">
                <li>Click the <strong>"Publish"</strong> button</li>
                <li>Your changes are live immediately</li>
                <li>Your website automatically updates</li>
              </ol>
              <p class="text-gray-500 text-sm mt-4 italic">
                No code knowledge needed—Sanity handles all the technical details!
              </p>
            </div>
          </section>

          <!-- Best Practices -->
          <section class="space-y-4">
            <h2 class="text-3xl font-bold text-gold">Best Practices</h2>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div class="bg-white bg-opacity-5 border border-gold border-opacity-20 rounded-lg p-6">
                <h3 class="text-lg font-bold text-gold mb-2">✓ Do</h3>
                <ul class="space-y-1 text-gray-300 text-sm">
                  <li>• Preview before publishing</li>
                  <li>• Use descriptive titles</li>
                  <li>• Optimize images</li>
                  <li>• Proofread carefully</li>
                  <li>• Use scheduled publishing</li>
                </ul>
              </div>
              <div class="bg-white bg-opacity-5 border border-gold border-opacity-20 rounded-lg p-6">
                <h3 class="text-lg font-bold text-gold mb-2">✗ Don't</h3>
                <ul class="space-y-1 text-gray-300 text-sm">
                  <li>• Upload huge files</li>
                  <li>• Use special characters in URLs</li>
                  <li>• Publish without reviewing</li>
                  <li>• Leave incomplete drafts</li>
                  <li>• Exceed character limits</li>
                </ul>
              </div>
            </div>
          </section>

          <!-- Common Tasks -->
          <section class="space-y-4">
            <h2 class="text-3xl font-bold text-gold">Common Tasks</h2>

            <div class="bg-white bg-opacity-5 border border-gold border-opacity-20 rounded-lg p-6">
              <h3 class="text-lg font-bold text-gold mb-3">Add a New Page/Post</h3>
              <ol class="list-decimal list-inside space-y-2 text-gray-300 ml-2">
                <li>Click "Create" in the top left</li>
                <li>Select the content type</li>
                <li>Fill in required fields</li>
                <li>Click "Publish"</li>
              </ol>
            </div>

            <div class="bg-white bg-opacity-5 border border-gold border-opacity-20 rounded-lg p-6">
              <h3 class="text-lg font-bold text-gold mb-3">Update Existing Content</h3>
              <ol class="list-decimal list-inside space-y-2 text-gray-300 ml-2">
                <li>Find the content in your dashboard</li>
                <li>Click to open it</li>
                <li>Make your changes</li>
                <li>Click "Publish" to go live</li>
              </ol>
            </div>

            <div class="bg-white bg-opacity-5 border border-gold border-opacity-20 rounded-lg p-6">
              <h3 class="text-lg font-bold text-gold mb-3">Upload Images</h3>
              <ol class="list-decimal list-inside space-y-2 text-gray-300 ml-2">
                <li>Click the image field</li>
                <li>Upload or paste your image</li>
                <li>Add alt text for accessibility</li>
                <li>Save and publish</li>
              </ol>
            </div>
          </section>

          <!-- Support -->
          <div class="bg-gold bg-opacity-10 border border-gold border-opacity-40 rounded-lg p-8">
            <h2 class="text-2xl font-bold text-gold mb-4">Need Help?</h2>
            <p class="text-gray-300 mb-4">
              If you have questions or run into issues:
            </p>
            <ul class="space-y-2 text-gray-300">
              <li>📧 Email your project manager</li>
              <li>💬 Use the Sanity support chat</li>
              <li>📚 Check Sanity's official documentation</li>
              <li>🆘 Contact Spirit Media directly</li>
            </ul>
          </div>

          <!-- Resources -->
          <section class="space-y-4">
            <h2 class="text-3xl font-bold text-gold">Resources</h2>
            <div class="bg-white bg-opacity-5 border border-gold border-opacity-20 rounded-lg p-6">
              <ul class="space-y-2 text-gray-300">
                <li>
                  <a href="https://www.sanity.io/docs" target="_blank" rel="noopener noreferrer" class="text-gold hover:underline">
                    → Sanity CMS Documentation
                  </a>
                </li>
                <li>
                  <a href="https://www.sanity.io/help" target="_blank" rel="noopener noreferrer" class="text-gold hover:underline">
                    → Sanity Help & Support
                  </a>
                </li>
              </ul>
            </div>
          </section>
        </section>
      </main>

      <!-- Footer -->
      <footer class="border-t border-gold border-opacity-20 bg-navy bg-opacity-50 mt-12">
        <div class="max-w-4xl mx-auto px-6 py-8 text-center text-gray-500 text-sm">
          <p>Spirit Media © 2024 | Powered by Sanity CMS</p>
        </div>
      </footer>
    </div>
  </body>
</html>
