---
import '../styles/globals.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Spirit Media Portal</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Shared Spirit Media brand tokens -->
    <link rel="stylesheet" href="https://spiritmediapublishing.com/spirit-media-tokens.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700;800&family=Source+Sans+3:wght@400;600;700&display=swap" rel="stylesheet" />
  </head>

  <body>
    <div class="portal-wrap">

      <!-- Sidebar -->
      <nav class="portal-sidebar">
        <div class="portal-logo">
          <span class="logo-spirit">Spirit</span>
          <span class="logo-media">Media</span>
          <div class="logo-sub">PORTAL</div>
        </div>

        <div class="portal-nav">
          <a href="/dashboard" class="portal-nav-link">Dashboard</a>
          <a href="/playbook" class="portal-nav-link">Playbook</a>
          <a href="/developers" class="portal-nav-link">Developers</a>
          <a href="/clients" class="portal-nav-link">Clients</a>
        </div>

        <div class="portal-sidebar-footer">
          <a href="/logout" class="portal-logout">Logout</a>
        </div>
      </nav>

      <!-- Main -->
      <main class="portal-main">
        <slot />
      </main>

    </div>
  </body>
</html>

<style>
  .portal-wrap {
    display: flex;
    min-height: 100vh;
    background-color: #faf8f5;
  }

  /* Sidebar */
  .portal-sidebar {
    width: 240px;
    min-height: 100vh;
    background-color: #1a1714;
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
  }

  .portal-logo {
    padding: 2rem 1.5rem 1.5rem;
    border-bottom: 1px solid rgba(192, 57, 43, 0.25);
  }

  .logo-spirit {
    font-family: "Playfair Display", Georgia, serif;
    font-size: 1.5rem;
    font-weight: 800;
    color: #ffffff;
    letter-spacing: -0.01em;
  }

  .logo-media {
    font-family: "Playfair Display", Georgia, serif;
    font-size: 1.5rem;
    font-weight: 800;
    color: #c0392b;
    letter-spacing: -0.01em;
    margin-left: 0.35rem;
  }

  .logo-sub {
    font-family: "Source Sans 3", system-ui, sans-serif;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: #9e9285;
    margin-top: 0.25rem;
  }

  .portal-nav {
    flex: 1;
    padding: 1.5rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .portal-nav-link {
    display: block;
    padding: 0.65rem 1rem;
    font-family: "Source Sans 3", system-ui, sans-serif;
    font-size: 0.9375rem;
    font-weight: 600;
    color: #bfb4a4;
    border-radius: 0.375rem;
    transition: background 150ms, color 150ms;
    text-decoration: none;
  }

  .portal-nav-link:hover {
    background-color: rgba(192, 57, 43, 0.12);
    color: #ffffff;
  }

  .portal-sidebar-footer {
    padding: 1.5rem;
    border-top: 1px solid rgba(255,255,255,0.08);
  }

  .portal-logout {
    display: block;
    text-align: center;
    padding: 0.6rem 1rem;
    font-family: "Source Sans 3", system-ui, sans-serif;
    font-size: 0.875rem;
    font-weight: 700;
    color: #9e9285;
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 0.375rem;
    transition: all 150ms;
    text-decoration: none;
  }

  .portal-logout:hover {
    color: #ffffff;
    border-color: rgba(255,255,255,0.3);
  }

  /* Main content area */
  .portal-main {
    flex: 1;
    background-color: #faf8f5;
    padding: 2.5rem 3rem;
    overflow-y: auto;
  }
</style>
