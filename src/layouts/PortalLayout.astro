---
import "../styles/globals.css";
import MailtoLink from "../components/MailtoLink.astro";

interface Props {
	title: string;
	mainBg?: string;
}

const { title, mainBg } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title} | Spirit Media Portal</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Shared Spirit Media brand tokens -->
    <link rel="stylesheet" href="https://spiritmediapublishing.com/spirit-media-tokens.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700;800&family=Source+Sans+3:wght@400;600;700&display=swap" rel="stylesheet" />
    <slot name="head" />
  </head>

  <body>
    <div class="portal-wrap">

      <!-- Sidebar -->
      <nav class="portal-sidebar">
        <div class="portal-nav">
          <a href="/dashboard" class="portal-nav-link">Dashboard</a>
          <a href="/connecting" class="portal-nav-link">Connecting</a>
          <a href="/playbook" class="portal-nav-link">Playbook</a>
          <a href="/developers" class="portal-nav-link">Developers</a>
          <a href="/pipelines" class="portal-nav-link">Pipelines</a>
          <hr class="portal-nav-divider" />
          <a href="/clients" class="portal-nav-link">Clients</a>
          <a href="/design-library" class="portal-nav-link">Design Library</a>
        </div>

        <div class="portal-sidebar-footer">
          <a href="/logout" class="portal-logout">Logout</a>
        </div>
      </nav>

      <!-- Main -->
      <main class="portal-main" style={mainBg ? `background-color: ${mainBg}` : undefined}>
        <header class="portal-header">
          <img src="https://cdn.sanity.io/images/pmowd8uo/production/dc16e3c604bd5d52de7647af46836ff418c22898-6575x656.png?w=440&h=88&fit=max&auto=format" alt="Spirit Media Publishing" class="portal-logo-img" />
          <p class="logo-sub">SMP PORTAL</p>
        </header>
        <slot />
        <footer class="portal-footer">
          <p>Spirit Media Publishing &copy; 2026 | <MailtoLink email="hello@spiritmediapublishing.com" /> | Powered by <a href="https://spiritmediapublishing.com" target="_blank" rel="noopener noreferrer">Spirit Media Publishing</a></p>
        </footer>
      </main>

    </div>
  </body>
</html>

<style>
  .portal-wrap {
    display: flex;
    min-height: 100vh;
    background-color: #faf8f5;
  }

  /* Sidebar */
  .portal-sidebar {
    width: 240px;
    min-height: 100vh;
    background-color: #d6d3d1;
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
  }

  .portal-header {
    padding-bottom: 1.5rem;
    margin-bottom: 2rem;
    border-bottom: 1px solid #e7e5e4;
  }

  .portal-logo-img {
    height: 3rem;
    width: auto;
  }

  .logo-sub {
    font-family: "Source Sans 3", system-ui, sans-serif;
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: #78716c;
    margin-top: 0.5rem;
  }

  .portal-nav {
    flex: 1;
    padding: 1.5rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .portal-nav-link {
    display: block;
    padding: 0.65rem 1rem;
    font-family: "Source Sans 3", system-ui, sans-serif;
    font-size: 0.9375rem;
    font-weight: 600;
    color: #1c1917;
    border-radius: 0.375rem;
    transition: background 150ms, color 150ms;
    text-decoration: none;
  }

  .portal-nav-divider {
    border: none;
    border-top: 1px solid rgba(0, 0, 0, 0.12);
    margin: 8px 0;
  }

  .portal-nav-link:hover {
    background-color: rgba(0, 0, 0, 0.08);
    color: #c0392b;
  }

  .portal-sidebar-footer {
    padding: 1.5rem;
    border-top: 1px solid rgba(0, 0, 0, 0.1);
  }

  .portal-logout {
    display: block;
    text-align: center;
    padding: 0.6rem 1rem;
    font-family: "Source Sans 3", system-ui, sans-serif;
    font-size: 0.875rem;
    font-weight: 700;
    color: #1c1917;
    border: 1px solid rgba(0, 0, 0, 0.15);
    border-radius: 0.375rem;
    transition: all 150ms;
    text-decoration: none;
  }

  .portal-logout:hover {
    color: #c0392b;
    border-color: rgba(192, 57, 43, 0.4);
  }

  /* Main content area */
  .portal-main {
    flex: 1;
    background-color: #faf8f5;
    padding: 2.5rem 3rem;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
  }

  .portal-main > :first-child {
    flex: 1;
  }

  .portal-footer {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid #e7e5e4;
    text-align: center;
    font-family: "Source Sans 3", system-ui, sans-serif;
    font-size: 0.8125rem;
    color: #78716c;
  }

  .portal-footer a {
    color: #a8a29e;
    text-decoration: none;
  }

  .portal-footer a:hover {
    text-decoration: underline;
    color: #78716c;
  }
</style>
