---
import PortalLayout from "../layouts/PortalLayout.astro";
---

<PortalLayout title="Pipelines">
  <div class="max-w-3xl">
    <h1 class="text-4xl font-bold mb-2">Pipelines</h1>
    <p class="text-stone-600 mb-10">Automated tools organized by department.</p>

    <!-- ══════════════════════════════════════════════════════════
         PRE-SALE — PROPOSAL GENERATOR — amber
    ═══════════════════════════════════════════════════════════ -->
    <div class="mb-12 bg-green-50 rounded-2xl border border-green-200 p-8">
      <div class="flex items-center gap-3 mb-4">
        <span class="inline-block px-3 py-1 rounded-full bg-green-200 text-green-800 text-xs font-bold uppercase tracking-widest">Pre-Sale</span>
      </div>

      <div class="bg-white rounded-2xl border border-green-200 p-8 shadow-sm">
        <div class="flex items-center justify-between mb-1">
          <h2 class="text-2xl font-bold">Website Migration Proposal</h2>
          <a href="https://drive.google.com/drive/folders/1k4JyJmlVpoi0xEZKsaf1YAgMpjxB-Cu7?usp=drive_link" target="_blank" rel="noopener noreferrer" class="text-xs font-semibold text-green-700 hover:underline">Google Drive Folder &rarr;</a>
        </div>
        <p class="text-stone-500 text-sm mb-6">Enter the client's current site URL. Generates the Website Modernization Proposal (Google Doc). Sales tool only — when the sale closes, follow the <a href="/playbook" class="text-green-700 hover:underline font-semibold">Migration Protocol</a> on the Playbook.</p>
        <form id="proposal-form" class="space-y-4">
          <input type="url" id="site-url" required placeholder="https://clientsite.com"
            class="w-full border border-stone-300 rounded-lg px-4 py-3 text-stone-800 placeholder-stone-400 focus:outline-none focus:ring-2 focus:ring-green-300 text-base" />
          <button type="submit" id="proposal-btn"
            class="w-full bg-green-700 hover:bg-green-800 text-white font-semibold py-3 px-6 rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
            Generate Proposal
          </button>
        </form>
        <div id="proposal-status" class="hidden mt-5">
          <div id="proposal-spinner" class="hidden flex items-center gap-3 text-stone-600 text-sm">
            <svg class="animate-spin h-4 w-4 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path></svg>
            <span>Auditing site and building proposal — 2–4 minutes…</span>
          </div>
          <div id="proposal-result" class="hidden p-5 bg-green-50 border border-green-200 rounded-xl space-y-2">
            <p class="text-sm font-bold text-green-800">Proposal ready!</p>
            <a id="proposal-link" href="#" target="_blank" rel="noopener noreferrer" class="block text-green-700 underline font-medium text-sm">Open Proposal →</a>
            <p class="text-xs text-stone-500 pt-1">When the sale closes, start Phase 1 in the Migration Pipeline below.</p>
          </div>
          <div id="proposal-error" class="hidden p-4 bg-red-50 border border-red-200 rounded-xl">
            <p class="text-sm font-bold text-red-800 mb-1">Error</p>
            <p id="proposal-error-text" class="text-sm text-red-700 font-mono whitespace-pre-wrap"></p>
          </div>
          <div id="proposal-challenge" class="hidden p-6 bg-amber-50 border border-amber-200 rounded-xl">
            <p class="text-sm font-bold text-amber-800 mb-2">Cloudflare Verification Required</p>
            <p class="text-xs text-stone-600 mb-3">This site requires human verification. Click the CAPTCHA checkbox in the image below to proceed.</p>
            <div class="relative inline-block cursor-pointer border border-stone-300 rounded-lg overflow-hidden">
              <img id="challenge-img" src="" alt="Cloudflare challenge" class="max-w-full" style="max-height: 500px;" />
            </div>
            <div class="mt-3 flex gap-3">
              <button id="challenge-refresh" class="text-xs text-amber-700 underline hover:text-amber-900">Refresh Screenshot</button>
              <button id="challenge-dismiss" class="text-xs text-red-600 underline hover:text-red-800">Skip (abort proposal)</button>
            </div>
            <p id="challenge-status-text" class="text-xs text-stone-500 mt-2">Click on the checkbox in the image above.</p>
          </div>
        </div>
      </div>
      <!-- Prospect Finder card -->
      <div class="bg-white rounded-2xl border border-green-200 p-8 shadow-sm mt-6">
        <div class="flex items-center justify-between mb-1">
          <h2 class="text-2xl font-bold">Prospect Finder</h2>
        </div>
        <p class="text-stone-500 text-sm mb-6">Search for prospects by keyword or paste URLs directly. Audits each site, scores SMP fit (0-10), and extracts contact info. Generate proposals for top prospects in one click.</p>

        <!-- Mode tabs -->
        <div class="flex gap-2 mb-4">
          <button id="pf-tab-urls" class="px-4 py-1.5 rounded-full text-sm font-semibold bg-green-700 text-white transition-colors">Paste URLs</button>
          <button id="pf-tab-search" class="px-4 py-1.5 rounded-full text-sm font-semibold border border-stone-300 text-stone-600 hover:border-green-500 hover:text-green-700 transition-colors">Search</button>
        </div>

        <form id="prospect-form" class="space-y-4">
          <!-- URL mode (default) -->
          <div id="pf-urls-input">
            <textarea id="pf-urls" rows="4" required placeholder="Paste URLs (one per line)&#10;https://example-church.org&#10;https://coachingsite.com&#10;https://smallbiz.net"
              class="w-full border border-stone-300 rounded-lg px-4 py-3 text-stone-800 placeholder-stone-400 focus:outline-none focus:ring-2 focus:ring-green-300 text-sm font-mono"></textarea>
          </div>
          <!-- Search mode (hidden by default) -->
          <div id="pf-search-input" class="hidden">
            <input type="text" id="pf-query" placeholder="e.g. churches in raleigh nc, life coaches in charlotte"
              class="w-full border border-stone-300 rounded-lg px-4 py-3 text-stone-800 placeholder-stone-400 focus:outline-none focus:ring-2 focus:ring-green-300 text-base" />
          </div>
          <button type="submit" id="prospect-btn"
            class="w-full bg-green-700 hover:bg-green-800 text-white font-semibold py-3 px-6 rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
            Scan Prospects
          </button>
        </form>

        <!-- Status -->
        <div id="pf-status" class="hidden mt-5">
          <div id="pf-spinner" class="hidden flex items-center gap-3 text-stone-600 text-sm">
            <svg class="animate-spin h-4 w-4 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path></svg>
            <span id="pf-spinner-text">Starting scan...</span>
          </div>
          <div id="pf-error" class="hidden p-4 bg-red-50 border border-red-200 rounded-xl">
            <p class="text-sm font-bold text-red-800 mb-1">Error</p>
            <p id="pf-error-text" class="text-sm text-red-700 font-mono whitespace-pre-wrap"></p>
          </div>
        </div>

        <!-- Results table -->
        <div id="pf-results" class="hidden mt-6">
          <div class="flex items-center justify-between mb-4">
            <h3 class="text-lg font-bold text-stone-800">Results</h3>
            <div id="pf-summary" class="flex gap-3 text-xs font-semibold"></div>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-stone-200 text-left text-xs text-stone-500 uppercase tracking-wider">
                  <th class="py-2 pr-3"><input type="checkbox" id="pf-select-all" class="rounded" /></th>
                  <th class="py-2 pr-3">Score</th>
                  <th class="py-2 pr-3">Site</th>
                  <th class="py-2 pr-3">Platform</th>
                  <th class="py-2 pr-3">Pages</th>
                  <th class="py-2 pr-3">Mobile</th>
                  <th class="py-2 pr-3">Contact</th>
                  <th class="py-2 pr-3">Flags</th>
                </tr>
              </thead>
              <tbody id="pf-table-body"></tbody>
            </table>
          </div>
          <div class="mt-4 flex gap-3">
            <button id="pf-propose-btn" class="bg-green-700 hover:bg-green-800 text-white font-semibold py-2 px-5 rounded-lg text-sm transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
              Generate Proposals for Selected
            </button>
          </div>
          <div id="pf-propose-status" class="hidden mt-3 text-sm text-stone-600"></div>
        </div>
      </div>
    </div><!-- end Pre-Sale -->

    <!-- Migration, New Site, and Shared Tools moved to Playbook -->
    <div class="mb-12 bg-stone-50 rounded-2xl border border-stone-200 p-6 text-center">
      <p class="text-stone-600 text-sm"><strong>Website Migration</strong>, <strong>New Site Build</strong>, and <strong>Shared Dev Tools</strong> are now run as Claude Code commands from your own session.</p>
      <p class="text-stone-500 text-sm mt-2">See the <a href="/playbook" class="text-rose-700 hover:underline font-semibold">Playbook</a> for the full protocol, phases, and command reference.</p>
    </div>

    <!-- ══════════════════════════════════════════════════════════
         PUBLISHING — blue
    ═══════════════════════════════════════════════════════════ -->
    <div class="mb-12 bg-indigo-50 rounded-2xl border border-indigo-200 p-8">
      <div class="flex items-center gap-3 mb-4">
        <span class="inline-block px-3 py-1 rounded-full bg-indigo-200 text-indigo-800 text-xs font-bold uppercase tracking-widest">Publishing</span>
      </div>

      <!-- Manuscript Review -->
      <div class="bg-white rounded-2xl border border-indigo-200 p-8 mb-6 shadow-sm">
        <h2 class="text-2xl font-bold mb-1">Manuscript Review Generator</h2>
        <p class="text-stone-500 text-sm mb-6">Paste a Google Drive link — Google Doc, Word, or PDF all work. Generates both the client review and internal brief.</p>
        <form id="generate-form" class="space-y-6">
          <div>
            <label for="file-url" class="block text-sm font-semibold text-stone-700 mb-2">Manuscript Link</label>
            <input type="url" id="file-url" name="file_url" required placeholder="https://docs.google.com/document/d/…"
              class="w-full border border-stone-300 rounded-lg px-4 py-3 text-stone-800 placeholder-stone-400 focus:outline-none focus:ring-2 focus:ring-blue-300" />
            <p class="text-xs text-stone-500 mt-1">Supports Google Docs, Word (.docx), and PDF files from Google Drive.</p>
          </div>
          <button type="submit" id="generate-btn"
            class="w-full bg-blue-200 hover:bg-blue-300 text-blue-900 font-semibold py-3 px-6 rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
            Generate Review
          </button>
        </form>
        <div id="generate-status" class="hidden mt-6">
          <div id="generate-spinner" class="hidden flex items-center gap-3 text-stone-600">
            <svg class="animate-spin h-5 w-5 text-stone-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path></svg>
            <span id="generate-status-text">Reading manuscript…</span>
          </div>
          <div id="generate-result" class="hidden p-4 bg-green-50 border border-green-200 rounded-lg space-y-2">
            <p class="text-sm font-semibold text-green-800 mb-2">Done!</p>
            <div id="generate-result-review" class="hidden"><span class="text-xs font-semibold text-green-600 uppercase tracking-wider">Client Review:</span> <a id="generate-result-link" href="#" target="_blank" rel="noopener noreferrer" class="text-green-700 underline font-medium break-all"></a></div>
            <div id="generate-result-eval" class="hidden"><span class="text-xs font-semibold text-green-600 uppercase tracking-wider">Internal Brief:</span> <a id="generate-result-eval-link" href="#" target="_blank" rel="noopener noreferrer" class="text-green-700 underline font-medium break-all"></a></div>
            <div id="generate-result-verdict" class="hidden"><span class="text-xs font-semibold text-stone-500 uppercase tracking-wider">Verdict:</span> <span id="generate-verdict-text" class="text-sm font-bold text-stone-800"></span></div>
          </div>
          <div id="generate-error" class="hidden p-4 bg-red-50 border border-red-200 rounded-lg">
            <p class="text-sm font-semibold text-red-800 mb-1">Error</p>
            <p id="generate-error-text" class="text-sm text-red-700"></p>
          </div>
        </div>
      </div>
      <!-- Cover Generator -->
      <div class="bg-white rounded-2xl border border-indigo-200 p-8 shadow-sm">
        <h2 class="text-2xl font-bold mb-1">Cover Generator</h2>
        <p class="text-stone-500 text-sm mb-6">Upload a finished front cover, fill in the back-cover content, get a print-ready KDP wrap PDF + preview. Per-book folder lives at <code class="bg-stone-100 px-1 rounded text-xs">/home/deploy/covers/&lt;slug&gt;</code>; refine with Claude on Bethel by slug after generation.</p>
        <form id="cover-form" class="space-y-4">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-semibold text-stone-700 mb-1">Title <span class="text-red-600">*</span></label>
              <input type="text" name="title" required class="w-full border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-stone-700 mb-1">Subtitle</label>
              <input type="text" name="subtitle" class="w-full border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-stone-700 mb-1">Author <span class="text-red-600">*</span></label>
              <input type="text" name="author_primary" required class="w-full border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-stone-700 mb-1">Slug <span class="text-stone-400 font-normal">(auto from title)</span></label>
              <input type="text" name="slug" placeholder="lowercase-with-hyphens" pattern="[a-z0-9][a-z0-9-]*" class="w-full border border-stone-300 rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-indigo-300" />
            </div>
          </div>

          <div>
            <label class="block text-sm font-semibold text-stone-700 mb-1">Top Headline (italic, above description) <span class="text-red-600">*</span></label>
            <input type="text" name="back_headline_top" required class="w-full border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
          </div>

          <div>
            <label class="block text-sm font-semibold text-stone-700 mb-1">Book Description <span class="text-red-600">*</span></label>
            <textarea name="book_description" required rows="5" class="w-full border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"></textarea>
          </div>

          <div>
            <label class="block text-sm font-semibold text-stone-700 mb-1">Bottom Headline <span class="text-stone-400 font-normal">(optional, between description and bio)</span></label>
            <input type="text" name="back_headline_bottom" class="w-full border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
          </div>

          <div>
            <label class="block text-sm font-semibold text-stone-700 mb-1">Author Bio <span class="text-red-600">*</span></label>
            <textarea name="author_bio" required rows="4" class="w-full border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"></textarea>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div class="md:col-span-2">
              <label class="block text-sm font-semibold text-stone-700 mb-1">BISAC <span class="text-red-600">*</span></label>
              <input type="text" name="bisac" required placeholder="Christian Books & Bibles / Christian Fiction / Inspirational" class="w-full border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
              <p class="text-xs text-stone-500 mt-1">Slash-separated; renders with bullet separators on the cover.</p>
            </div>
            <div>
              <label class="block text-sm font-semibold text-stone-700 mb-1">Price (USD) <span class="text-red-600">*</span></label>
              <input type="number" name="price_usd" required step="0.01" min="0.99" max="99.99" placeholder="14.99" class="w-full border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div>
              <label class="block text-sm font-semibold text-stone-700 mb-1">ISBN-13 <span class="text-red-600">*</span></label>
              <input type="text" name="isbn" required placeholder="979-8-89307-263-1" class="w-full border border-stone-300 rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-indigo-300" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-stone-700 mb-1">Pages <span class="text-stone-400 font-normal">(for spine width)</span></label>
              <input type="number" name="pages" min="24" max="828" placeholder="220" class="w-full border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-stone-700 mb-1">Paper</label>
              <select name="paper_type" class="w-full border border-stone-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300">
                <option value="white">White (default)</option>
                <option value="cream">Cream</option>
              </select>
            </div>
          </div>

          <div class="border-t border-stone-200 pt-4 space-y-3">
            <p class="text-sm font-semibold text-stone-700">Files</p>
            <div>
              <label class="block text-sm font-semibold text-stone-700 mb-1">Front Cover <span class="text-red-600">*</span></label>
              <input type="file" name="front_cover" accept="image/png" required class="w-full text-sm text-stone-700 file:mr-3 file:py-1.5 file:px-3 file:rounded-md file:border-0 file:bg-indigo-100 file:text-indigo-800 file:text-sm file:font-semibold hover:file:bg-indigo-200" />
              <p class="text-xs text-stone-500 mt-1">PNG at trim+bleed. Carries any sub-brand badge (Express Books etc.) baked in.</p>
            </div>
            <div>
              <label class="block text-sm font-semibold text-stone-700 mb-1">Author Headshot <span class="text-red-600">*</span></label>
              <input type="file" name="headshot" accept="image/png,image/jpeg" required class="w-full text-sm text-stone-700 file:mr-3 file:py-1.5 file:px-3 file:rounded-md file:border-0 file:bg-indigo-100 file:text-indigo-800 file:text-sm file:font-semibold hover:file:bg-indigo-200" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-stone-700 mb-1">Back Painting Wrap <span class="text-stone-400 font-normal">(optional — wrap-width painting; falls back to front cover)</span></label>
              <input type="file" name="back_painting_wrap" accept="image/png" class="w-full text-sm text-stone-700 file:mr-3 file:py-1.5 file:px-3 file:rounded-md file:border-0 file:bg-indigo-100 file:text-indigo-800 file:text-sm file:font-semibold hover:file:bg-indigo-200" />
            </div>
          </div>

          <button type="submit" id="cover-btn"
            class="w-full bg-indigo-700 hover:bg-indigo-800 text-white font-semibold py-3 px-6 rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
            Generate Cover
          </button>
        </form>

        <div id="cover-status" class="hidden mt-6">
          <div id="cover-spinner" class="hidden flex items-center gap-3 text-stone-600 text-sm">
            <svg class="animate-spin h-5 w-5 text-indigo-700" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path></svg>
            <span id="cover-status-text">Building cover — 30-60s…</span>
          </div>
          <div id="cover-result" class="hidden p-5 bg-indigo-50 border border-indigo-200 rounded-xl space-y-3">
            <p class="text-sm font-bold text-indigo-800">Cover ready!</p>
            <p class="text-xs text-stone-600"><span class="font-semibold">Slug:</span> <code id="cover-result-slug" class="bg-white px-1.5 py-0.5 rounded font-mono"></code> &nbsp; <span class="font-semibold">Spine:</span> <span id="cover-result-spine"></span></p>
            <img id="cover-result-preview" src="" alt="Cover preview" class="w-full rounded-lg border border-stone-300 shadow-sm" />
            <div class="flex gap-3">
              <a id="cover-result-pdf" href="#" download class="inline-flex items-center gap-2 bg-indigo-700 hover:bg-indigo-800 text-white font-semibold py-2 px-4 rounded-lg text-sm transition-colors">
                <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5"/></svg>
                Download KDP PDF
              </a>
              <a id="cover-result-png" href="#" download class="inline-flex items-center gap-2 border border-indigo-300 text-indigo-800 font-semibold py-2 px-4 rounded-lg text-sm hover:bg-indigo-100 transition-colors">
                Download Preview PNG
              </a>
            </div>
            <p class="text-xs text-stone-500 pt-1">To refine: <code class="bg-stone-100 px-1 rounded">cd /home/deploy/covers/&lt;slug&gt; &amp;&amp; claude</code> on Bethel.</p>
          </div>
          <div id="cover-error" class="hidden p-4 bg-red-50 border border-red-200 rounded-xl">
            <p class="text-sm font-bold text-red-800 mb-1">Error</p>
            <p id="cover-error-text" class="text-sm text-red-700 font-mono whitespace-pre-wrap"></p>
          </div>
        </div>
      </div>

    </div><!-- end Publishing -->

    <!-- ══════════════════════════════════════════════════════════
         MARKETING — green
    ═══════════════════════════════════════════════════════════ -->
    <div class="mb-12 bg-emerald-50 rounded-2xl border border-emerald-200 p-8">
      <div class="flex items-center gap-3 mb-4">
        <span class="inline-block px-3 py-1 rounded-full bg-emerald-200 text-emerald-800 text-xs font-bold uppercase tracking-widest">Marketing</span>
      </div>

      <!-- Blog Post Publisher -->
      <div class="bg-white rounded-2xl border border-emerald-200 p-8 mb-6 shadow-sm">
        <h2 class="text-2xl font-bold mb-1">Compose Blog Post</h2>
        <p class="text-stone-500 text-sm mb-6">Pick a site and paste any raw source — voice memo, notes, ideas, an article from elsewhere. Claude writes a polished post in your voice for that site's audience and saves it as a Sanity draft for your review.</p>
        <form id="blog-form" class="space-y-5">
          <div>
            <label for="blog-site" class="block text-sm font-semibold text-stone-700 mb-2">Site</label>
            <select id="blog-site" name="site" required
              class="w-full border border-stone-300 rounded-lg px-4 py-3 text-stone-800 focus:outline-none focus:ring-2 focus:ring-emerald-300 bg-white">
              <option value="" disabled>Loading sites…</option>
            </select>
            <p class="text-xs text-stone-400 mt-1">The post lands as a Sanity draft on the selected site. You review and publish from Sanity Studio.</p>
          </div>
          <div>
            <label for="blog-content" class="block text-sm font-semibold text-stone-700 mb-2">Source Material</label>
            <textarea id="blog-content" name="content" required rows="14" placeholder="Paste anything — a voice memo transcript, rough notes, bullet points, an article you want to riff off, or a draft from elsewhere. The messier the better. Claude turns it into a polished post in your voice for this site's audience."
              class="w-full border border-stone-300 rounded-lg px-4 py-3 text-stone-800 placeholder-stone-400 focus:outline-none focus:ring-2 focus:ring-emerald-300 font-mono text-sm resize-y"></textarea>
            <p class="text-xs text-stone-400 mt-1">Composition takes ~30-60 seconds — Claude is writing 600-1200 words tailored to the site.</p>
          </div>
          <div>
            <label for="hero-image-url" class="block text-sm font-semibold text-stone-700 mb-2">Feature Image URL <span class="text-stone-400 font-normal">(optional)</span></label>
            <input type="url" id="hero-image-url" name="hero_image_url" placeholder="https://cdn.sanity.io/images/{project}/production/…"
              class="w-full border border-stone-300 rounded-lg px-4 py-3 text-stone-800 placeholder-stone-400 focus:outline-none focus:ring-2 focus:ring-emerald-300" />
            <p class="text-xs text-stone-400 mt-1">Upload in the site's Sanity Studio → copy the CDN URL → paste here. Must be from the same site's Sanity project.</p>
          </div>
          <button type="submit" id="blog-submit-btn"
            class="w-full bg-green-200 hover:bg-green-300 text-green-900 font-semibold py-3 px-6 rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
            Compose &amp; Save Draft
          </button>
        </form>
        <div id="blog-status" class="hidden mt-6">
          <div id="blog-spinner" class="hidden flex items-center gap-3 text-stone-600">
            <svg class="animate-spin h-5 w-5 text-stone-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path></svg>
            <span id="blog-status-text">Parsing content…</span>
          </div>
          <div id="blog-result" class="hidden p-5 bg-green-50 border border-green-200 rounded-lg space-y-2">
            <p class="text-sm font-semibold text-green-800">Draft saved!</p>
            <p class="text-xs text-green-700">Open in Sanity Studio to review, then click Publish when ready:</p>
            <a id="blog-studio-url" href="#" target="_blank" rel="noopener noreferrer" class="block text-sm text-green-700 underline font-medium break-all"></a>
            <p class="text-xs text-green-600 mt-2">Live URL once published:</p>
            <a id="blog-live-url" href="#" target="_blank" rel="noopener noreferrer" class="block text-xs text-green-600 underline break-all"></a>
          </div>
          <div id="blog-error" class="hidden p-4 bg-red-50 border border-red-200 rounded-lg">
            <p class="text-sm font-semibold text-red-800 mb-1">Error</p>
            <p id="blog-error-text" class="text-sm text-red-700"></p>
          </div>
        </div>
      </div>
    </div><!-- end Marketing -->

    <!-- ══════════════════════════════════════════════════════════
         GENERAL — purple
    ═══════════════════════════════════════════════════════════ -->
    <div class="mb-12 bg-stone-100 rounded-2xl border border-stone-200 p-8">
      <div class="flex items-center gap-3 mb-4">
        <span class="inline-block px-3 py-1 rounded-full bg-stone-300 text-stone-800 text-xs font-bold uppercase tracking-widest">Claude Agents</span>
      </div>
      <p class="text-stone-600 text-sm mb-6">Ask Claude to do something — code changes or general tasks.</p>

      <!-- Claude Task Agent -->
      <div class="bg-white rounded-2xl border border-stone-200 p-8 mb-6 shadow-sm">
        <h2 class="text-2xl font-bold mb-1">Claude Task Agent</h2>
        <p class="text-stone-500 text-sm mb-4">Describe any task in plain English — no site slug needed. Claude handles it and returns a response you can copy or act on.</p>

        <div class="bg-stone-50 border border-stone-200 rounded-lg p-4 mb-6">
          <p class="text-xs font-bold uppercase tracking-widest text-stone-500 mb-2">What this agent can help with</p>
          <ul class="grid grid-cols-2 gap-x-4 gap-y-1 text-stone-700 text-sm">
            <li>• Draft an email or letter</li>
            <li>• Write marketing or ad copy</li>
            <li>• Summarize a document or URL</li>
            <li>• Create social media posts</li>
            <li>• Outline a sermon or Bible study</li>
            <li>• Write a proposal or pitch</li>
            <li>• Brainstorm names or taglines</li>
            <li>• Draft meeting agendas or notes</li>
            <li>• Rewrite or edit any copy</li>
            <li>• Answer a research question</li>
          </ul>
        </div>

        <form id="general-form" class="space-y-4">
          <div>
            <label for="general-task" class="block text-sm font-semibold text-stone-700 mb-2">What do you need?</label>
            <textarea id="general-task" required rows="5"
              placeholder="e.g. Write a 3-sentence email to a potential client introducing Spirit Media Publishing and our website services. Keep it warm and pastoral."
              class="w-full border border-stone-300 rounded-lg px-4 py-3 text-stone-800 placeholder-stone-400 focus:outline-none focus:ring-2 focus:ring-stone-400 resize-y text-sm"></textarea>
            <p class="text-xs text-stone-400 mt-1">The more context you give, the better the result.</p>
          </div>
          <button type="submit" id="general-btn"
            class="w-full bg-stone-700 hover:bg-stone-800 text-white font-semibold py-3 rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
            Run Task
          </button>
        </form>

        <div id="general-status" class="hidden mt-5">
          <div id="general-spinner" class="hidden flex items-center gap-3 text-stone-500 text-sm">
            <svg class="animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path></svg>
            <span id="general-status-text">Working on it…</span>
          </div>
          <div id="general-result" class="hidden mt-4">
            <div class="flex items-center justify-between mb-2">
              <p class="text-sm font-semibold text-stone-700">Result</p>
              <button id="general-copy-btn" class="px-3 py-1 bg-violet-50 hover:bg-violet-100 text-violet-700 rounded text-xs font-semibold">Copy</button>
            </div>
            <div id="general-response" class="bg-stone-50 border border-stone-200 rounded-lg px-4 py-3 text-sm text-stone-800 whitespace-pre-wrap leading-relaxed"></div>
          </div>
          <div id="general-error" class="hidden p-4 bg-red-50 border border-red-200 rounded-lg">
            <p class="font-semibold text-red-800 text-sm mb-1">Something went wrong</p>
            <p id="general-error-text" class="text-red-700 text-sm"></p>
          </div>
        </div>
      </div>
    </div><!-- end General -->

    <!-- Recent Documents -->
    <div>
      <h2 class="text-2xl font-bold mb-4">Recent Documents</h2>
      <div id="history-list" class="space-y-2">
        <p class="text-stone-500 text-sm">Loading…</p>
      </div>
    </div>
  </div>
</PortalLayout>

<script>
if (!(window as any).__portalInitialized) {
  (window as any).__portalInitialized = true;

  // ── Project registry removed — bootstrap/QA triggers now run via Claude Code commands ──

  // ── 1. Proposal ──────────────────────────────────────────────
  document.getElementById('proposal-form')!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const url = (document.getElementById('site-url') as HTMLInputElement).value.trim();
    const btn = document.getElementById('proposal-btn') as HTMLButtonElement;
    btn.disabled = true; btn.textContent = 'Generating…';
    document.getElementById('proposal-status')!.classList.remove('hidden');
    document.getElementById('proposal-spinner')!.classList.remove('hidden');
    ['proposal-result','proposal-error'].forEach(id => document.getElementById(id)!.classList.add('hidden'));
    try {
      const resp = await fetch('/api/tools-proposal', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ url }) });
      const start = await resp.json();
      if (start.error) throw new Error(start.error);
      let challengeSetup = false;
      const poll = async (): Promise<void> => {
        await new Promise(r => setTimeout(r, 4000));
        const job = await (await fetch(`/api/tools-proposal-status?job_id=${start.job_id}`)).json();
        if (job.status === 'pending') {
          // Hide challenge UI if it was showing (challenge solved, proposal resumed)
          document.getElementById('proposal-challenge')!.classList.add('hidden');
          document.getElementById('proposal-spinner')!.classList.remove('hidden');
          return poll();
        }
        if (job.status === 'challenge_required') {
          // Show challenge UI
          document.getElementById('proposal-spinner')!.classList.add('hidden');
          document.getElementById('proposal-challenge')!.classList.remove('hidden');
          // Fetch initial screenshot
          try {
            const ss = await (await fetch(`/api/tools-proposal-challenge?job_id=${start.job_id}`)).json();
            if (ss.image) (document.getElementById('challenge-img') as HTMLImageElement).src = ss.image;
          } catch {}
          // Set up click handlers (once)
          if (!challengeSetup) {
            challengeSetup = true;
            const img = document.getElementById('challenge-img') as HTMLImageElement;
            img.addEventListener('click', async (ev) => {
              const rect = img.getBoundingClientRect();
              const scaleX = img.naturalWidth / rect.width;
              const scaleY = img.naturalHeight / rect.height;
              const x = Math.round((ev.clientX - rect.left) * scaleX);
              const y = Math.round((ev.clientY - rect.top) * scaleY);
              document.getElementById('challenge-status-text')!.textContent = 'Sending click...';
              try {
                const resp = await fetch('/api/tools-proposal-challenge', {
                  method: 'POST', headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ job_id: start.job_id, x, y }),
                });
                const result = await resp.json();
                if (result.image) img.src = result.image;
                document.getElementById('challenge-status-text')!.textContent =
                  result.status === 'solved' ? 'Challenge solved! Resuming proposal...' : 'Click sent. Waiting...';
              } catch { document.getElementById('challenge-status-text')!.textContent = 'Click failed — try again.'; }
            });
            document.getElementById('challenge-dismiss')!.addEventListener('click', async () => {
              await fetch('/api/tools-proposal-challenge-dismiss', {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ job_id: start.job_id }),
              });
              document.getElementById('challenge-status-text')!.textContent = 'Dismissed — waiting for abort...';
            });
            document.getElementById('challenge-refresh')!.addEventListener('click', async () => {
              try {
                const ss = await (await fetch(`/api/tools-proposal-challenge?job_id=${start.job_id}`)).json();
                if (ss.image) img.src = ss.image;
              } catch {}
            });
          }
          return poll();
        }
        document.getElementById('proposal-spinner')!.classList.add('hidden');
        document.getElementById('proposal-challenge')!.classList.add('hidden');
        if (job.status === 'failed') {
          document.getElementById('proposal-error')!.classList.remove('hidden');
          document.getElementById('proposal-error-text')!.textContent = job.log || 'Proposal generation failed.';
        } else {
          document.getElementById('proposal-result')!.classList.remove('hidden');
          (document.getElementById('proposal-link') as HTMLAnchorElement).href = job.proposal_url;
        }
        btn.disabled = false; btn.textContent = 'Generate Proposal';
      };
      poll();
    } catch (err: any) {
      document.getElementById('proposal-spinner')!.classList.add('hidden');
      document.getElementById('proposal-error')!.classList.remove('hidden');
      document.getElementById('proposal-error-text')!.textContent = err.message;
      btn.disabled = false; btn.textContent = 'Generate Proposal';
    }
  });

  // ── Bootstrap, New Site, Site Update, Pre-Launch QA, Post-Launch QA, Site Audit ──
  // Removed — all now run as Claude Code commands in the developer's own session.
  // See Shared Tools section for command reference.

  // ── Manuscript Review ─────────────────────────────────────────
  document.getElementById('generate-form')!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const btn = document.getElementById('generate-btn') as HTMLButtonElement;
    btn.disabled = true;
    document.getElementById('generate-status')!.classList.remove('hidden');
    document.getElementById('generate-spinner')!.classList.remove('hidden');
    ['generate-result','generate-error'].forEach(id => document.getElementById(id)!.classList.add('hidden'));
    const messages = ['Reading manuscript…', 'Running genre diagnosis & review…', 'Generating reports…', 'Creating Google Docs…'];
    let msgIdx = 0;
    const statusText = document.getElementById('generate-status-text')!;
    statusText.textContent = messages[0];
    const interval = setInterval(() => { msgIdx = Math.min(msgIdx + 1, messages.length - 1); statusText.textContent = messages[msgIdx]; }, 15000);
    try {
      const fd = new FormData(form);
      const payload = { template_id: 'manuscript-review', file_url: fd.get('file_url') };
      // Fire both reports in parallel
      const [reviewResp, evalResp] = await Promise.all([
        fetch('/api/tools-generate', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) }),
        fetch('/api/tools-manuscript-eval', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ file_url: payload.file_url, title: 'Manuscript' }) }),
      ]);
      clearInterval(interval);
      const reviewResult = await reviewResp.json();
      const evalResult = await evalResp.json();
      const hasReview = reviewResult.doc_url;
      const hasEval = evalResult.doc_url;
      if (!hasReview && !hasEval) throw new Error(reviewResult.error || evalResult.error || 'Both reports failed');
      document.getElementById('generate-spinner')!.classList.add('hidden');
      document.getElementById('generate-result')!.classList.remove('hidden');
      if (hasReview) {
        document.getElementById('generate-result-review')!.classList.remove('hidden');
        const rl = document.getElementById('generate-result-link') as HTMLAnchorElement;
        rl.href = reviewResult.doc_url; rl.textContent = reviewResult.doc_name || reviewResult.doc_url;
      }
      if (hasEval) {
        document.getElementById('generate-result-eval')!.classList.remove('hidden');
        const el = document.getElementById('generate-result-eval-link') as HTMLAnchorElement;
        el.href = evalResult.doc_url; el.textContent = evalResult.doc_name || evalResult.doc_url;
        if (evalResult.verdict) {
          document.getElementById('generate-result-verdict')!.classList.remove('hidden');
          document.getElementById('generate-verdict-text')!.textContent = evalResult.verdict;
        }
      }
      loadHistory();
    } catch (err: any) {
      clearInterval(interval);
      document.getElementById('generate-spinner')!.classList.add('hidden');
      document.getElementById('generate-error')!.classList.remove('hidden');
      document.getElementById('generate-error-text')!.textContent = err.message;
    }
    btn.disabled = false;
  });

  // ── Blog Post Publisher ───────────────────────────────────────
  // Populate site dropdown from tools-api on page load
  (async () => {
    try {
      const resp = await fetch('/api/blog-sites');
      const data = await resp.json();
      const sel = document.getElementById('blog-site') as HTMLSelectElement;
      sel.innerHTML = '<option value="" disabled selected>Choose a site…</option>'
        + (data.sites || []).map((s: any) =>
            `<option value="${s.slug}">${s.label}</option>`).join('');
      // Default to FHB if available (current priority)
      if ((data.sites || []).some((s: any) => s.slug === 'fhb')) {
        sel.value = 'fhb';
      }
    } catch (err) {
      console.error('Failed to load blog sites:', err);
    }
  })();

  document.getElementById('blog-form')!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const btn = document.getElementById('blog-submit-btn') as HTMLButtonElement;
    btn.disabled = true;
    document.getElementById('blog-status')!.classList.remove('hidden');
    document.getElementById('blog-spinner')!.classList.remove('hidden');
    ['blog-result','blog-error'].forEach(id => document.getElementById(id)!.classList.add('hidden'));
    const messages = ['Reading source material…', 'Composing post in your voice…', 'Polishing SEO + tags…', 'Saving draft to Sanity…'];
    let msgIdx = 0;
    const statusText = document.getElementById('blog-status-text')!;
    statusText.textContent = messages[0];
    const interval = setInterval(() => { msgIdx = Math.min(msgIdx + 1, messages.length - 1); statusText.textContent = messages[msgIdx]; }, 8000);
    try {
      const fd = new FormData(form);
      const resp = await fetch('/api/blog-post', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ site: fd.get('site'), content: fd.get('content'), hero_image_url: fd.get('hero_image_url') || '' }) });
      clearInterval(interval);
      const result = await resp.json();
      if (result.url) {
        document.getElementById('blog-spinner')!.classList.add('hidden');
        document.getElementById('blog-result')!.classList.remove('hidden');
        const lu = document.getElementById('blog-live-url') as HTMLAnchorElement;
        const su = document.getElementById('blog-studio-url') as HTMLAnchorElement;
        lu.href = result.url; lu.textContent = result.url;
        su.href = result.sanity_studio; su.textContent = 'Open in Sanity Studio →';
        (form as HTMLFormElement).reset();
      } else { throw new Error(result.error || 'Unknown error'); }
    } catch (err: any) {
      clearInterval(interval);
      document.getElementById('blog-spinner')!.classList.add('hidden');
      document.getElementById('blog-error')!.classList.remove('hidden');
      document.getElementById('blog-error-text')!.textContent = err.message;
    }
    btn.disabled = false;
  });

  // ── General Agent ─────────────────────────────────────────────
  document.getElementById('general-form')!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const taskText = (document.getElementById('general-task') as HTMLTextAreaElement).value.trim();
    const btn = document.getElementById('general-btn') as HTMLButtonElement;
    btn.disabled = true; btn.textContent = 'Working…';
    document.getElementById('general-status')!.classList.remove('hidden');
    document.getElementById('general-spinner')!.classList.remove('hidden');
    ['general-result','general-error'].forEach(id => document.getElementById(id)!.classList.add('hidden'));
    const messages = ['Working on it…', 'Almost there…'];
    let i = 0;
    const statusText = document.getElementById('general-status-text')!;
    statusText.textContent = messages[0];
    const interval = setInterval(() => { i = Math.min(i + 1, messages.length - 1); statusText.textContent = messages[i]; }, 20000);
    try {
      const resp = await fetch('/api/tools-general', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ task_text: taskText }) });
      const start = await resp.json();
      if (start.error) throw new Error(start.error);
      const poll = async (): Promise<void> => {
        await new Promise(r => setTimeout(r, 4000));
        const job = await (await fetch(`/api/tools-general?job_id=${start.job_id}`)).json();
        if (job.status === 'pending') return poll();
        clearInterval(interval);
        document.getElementById('general-spinner')!.classList.add('hidden');
        if (job.status === 'failed') {
          document.getElementById('general-error')!.classList.remove('hidden');
          document.getElementById('general-error-text')!.textContent = job.error || 'Something went wrong.';
        } else {
          document.getElementById('general-result')!.classList.remove('hidden');
          document.getElementById('general-response')!.textContent = job.response;
        }
        btn.disabled = false; btn.textContent = 'Run Task';
      };
      poll();
    } catch (err: any) {
      clearInterval(interval);
      document.getElementById('general-spinner')!.classList.add('hidden');
      document.getElementById('general-error')!.classList.remove('hidden');
      document.getElementById('general-error-text')!.textContent = err.message;
      btn.disabled = false; btn.textContent = 'Run Task';
    }
  });

  document.getElementById('general-copy-btn')!.addEventListener('click', () => {
    const text = document.getElementById('general-response')!.textContent || '';
    navigator.clipboard.writeText(text).then(() => {
      const btn = document.getElementById('general-copy-btn')!;
      const orig = btn.textContent;
      btn.textContent = 'Copied!';
      setTimeout(() => { btn.textContent = orig; }, 2000);
    });
  });

  // ── History ───────────────────────────────────────────────────
  async function loadHistory() {
    const list = document.getElementById('history-list')!;
    try {
      const resp = await fetch('/api/tools-history');
      const docs = await resp.json();
      if (!docs.length) { list.innerHTML = '<p class="text-stone-500 text-sm">No documents yet.</p>'; return; }
      list.innerHTML = docs.map((d: any) => `
        <div class="flex items-center justify-between py-3 border-b border-stone-100 last:border-0">
          <div>
            <a href="${d.url}" target="_blank" rel="noopener noreferrer" class="font-medium text-stone-800 hover:text-stone-600 underline">${d.name}</a>
            <span class="text-xs text-stone-400 ml-2">${d.created}</span>
          </div>
          <a href="${d.url}" target="_blank" rel="noopener noreferrer" class="text-xs text-stone-500 hover:text-stone-700 ml-4 shrink-0">Open →</a>
        </div>`).join('');
    } catch { list.innerHTML = '<p class="text-stone-500 text-sm">Could not load history.</p>'; }
  }

  // ── Pre-Launch QA, Post-Launch QA, Site Audit ──
  // Removed — now run as Claude Code commands in developer's own session.

  // ── Prospect Finder ─────────────────────────────────────────
  let pfMode: 'urls' | 'search' = 'urls';

  document.getElementById('pf-tab-urls')!.addEventListener('click', () => {
    pfMode = 'urls';
    document.getElementById('pf-urls-input')!.classList.remove('hidden');
    document.getElementById('pf-search-input')!.classList.add('hidden');
    document.getElementById('pf-tab-urls')!.className = 'px-4 py-1.5 rounded-full text-sm font-semibold bg-green-700 text-white transition-colors';
    document.getElementById('pf-tab-search')!.className = 'px-4 py-1.5 rounded-full text-sm font-semibold border border-stone-300 text-stone-600 hover:border-green-500 hover:text-green-700 transition-colors';
  });
  document.getElementById('pf-tab-search')!.addEventListener('click', () => {
    pfMode = 'search';
    document.getElementById('pf-urls-input')!.classList.add('hidden');
    document.getElementById('pf-search-input')!.classList.remove('hidden');
    document.getElementById('pf-tab-search')!.className = 'px-4 py-1.5 rounded-full text-sm font-semibold bg-green-700 text-white transition-colors';
    document.getElementById('pf-tab-urls')!.className = 'px-4 py-1.5 rounded-full text-sm font-semibold border border-stone-300 text-stone-600 hover:border-green-500 hover:text-green-700 transition-colors';
  });

  // Select all checkbox
  document.getElementById('pf-select-all')!.addEventListener('change', (e) => {
    const checked = (e.target as HTMLInputElement).checked;
    document.querySelectorAll<HTMLInputElement>('.pf-row-check').forEach(cb => { cb.checked = checked; });
  });

  document.getElementById('prospect-form')!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('prospect-btn') as HTMLButtonElement;
    btn.disabled = true; btn.textContent = 'Scanning...';

    // Build request body
    let body: any;
    if (pfMode === 'urls') {
      const raw = (document.getElementById('pf-urls') as HTMLTextAreaElement).value.trim();
      const urls = raw.split('\n').map(l => l.trim()).filter(l => l.length > 0);
      if (!urls.length) { btn.disabled = false; btn.textContent = 'Scan Prospects'; return; }
      body = { urls };
    } else {
      const query = (document.getElementById('pf-query') as HTMLInputElement).value.trim();
      if (!query) { btn.disabled = false; btn.textContent = 'Scan Prospects'; return; }
      body = { query };
    }

    // Show spinner, hide previous results
    document.getElementById('pf-status')!.classList.remove('hidden');
    document.getElementById('pf-spinner')!.classList.remove('hidden');
    document.getElementById('pf-spinner-text')!.textContent = 'Starting scan...';
    ['pf-error', 'pf-results'].forEach(id => document.getElementById(id)!.classList.add('hidden'));

    try {
      const resp = await fetch('/api/tools-prospect', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      const start = await resp.json();
      if (start.error) throw new Error(start.error);

      // Poll for results
      const poll = async (): Promise<void> => {
        await new Promise(r => setTimeout(r, 3000));
        const job = await (await fetch(`/api/tools-prospect-status?job_id=${start.job_id}`)).json();

        if (job.status === 'pending') {
          // Update progress text
          const p = job.progress;
          if (p) {
            if (p.phase === 'searching') document.getElementById('pf-spinner-text')!.textContent = `Searching${p.query ? ': ' + p.query : ''}...`;
            else if (p.phase === 'auditing') document.getElementById('pf-spinner-text')!.textContent = `Auditing sites: ${p.audited || 0}/${p.total || '?'}`;
            else if (p.phase === 'enriching') document.getElementById('pf-spinner-text')!.textContent = `Running PageSpeed: ${p.enriched || 0}/${p.total || '?'}`;
          }
          return poll();
        }

        document.getElementById('pf-spinner')!.classList.add('hidden');

        if (job.status === 'failed') {
          document.getElementById('pf-error')!.classList.remove('hidden');
          document.getElementById('pf-error-text')!.textContent = job.error || 'Scan failed.';
        } else if (job.status === 'done' && job.results) {
          renderProspectResults(job.results);
        }
        btn.disabled = false; btn.textContent = 'Scan Prospects';
      };
      poll();
    } catch (err: any) {
      document.getElementById('pf-spinner')!.classList.add('hidden');
      document.getElementById('pf-error')!.classList.remove('hidden');
      document.getElementById('pf-error-text')!.textContent = err.message || 'Unknown error';
      btn.disabled = false; btn.textContent = 'Scan Prospects';
    }
  });

  function renderProspectResults(results: any) {
    document.getElementById('pf-results')!.classList.remove('hidden');
    const s = results.summary || {};
    document.getElementById('pf-summary')!.innerHTML = [
      `<span class="text-red-600">Hot (8-10): ${s.hot || 0}</span>`,
      `<span class="text-amber-600">Warm (5-7): ${s.warm || 0}</span>`,
      `<span class="text-stone-400">Cold (0-4): ${s.cold || 0}</span>`,
      `<span class="text-stone-600">Total: ${s.total || 0}</span>`,
    ].join('');

    const tbody = document.getElementById('pf-table-body')!;
    tbody.innerHTML = (results.prospects || []).map((p: any) => {
      const scoreBg = p.smpScore >= 8 ? 'bg-red-100 text-red-800' : p.smpScore >= 5 ? 'bg-amber-100 text-amber-800' : 'bg-stone-100 text-stone-600';
      const perf = p.pagespeed ? `${p.pagespeed.performance}` : '—';
      const emails = (p.contacts?.emails || []).slice(0, 2);
      const phones = (p.contacts?.phones || []).slice(0, 1);
      const contactHtml = [...emails.map((e: string) => `<span class="text-green-700">${e}</span>`), ...phones.map((ph: string) => `<span class="text-stone-500">${ph}</span>`)].join('<br/>') || '<span class="text-stone-300">—</span>';
      const flags = [];
      if (p.faithSignals) flags.push('<span class="text-amber-600" title="Faith signals detected">&#10013;</span>');
      if (p.screening) flags.push(`<span class="text-red-500" title="${p.screening[0]?.vendor || p.screening[0]?.type || 'Flag'}">&#9888;</span>`);
      const domain = (() => { try { return new URL(p.url).hostname.replace(/^www\./,''); } catch { return p.url; } })();
      return `<tr class="border-b border-stone-100 hover:bg-stone-50">
        <td class="py-2.5 pr-3"><input type="checkbox" class="pf-row-check rounded" data-url="${p.url}" ${p.smpScore >= 7 ? 'checked' : ''} /></td>
        <td class="py-2.5 pr-3"><span class="inline-block px-2 py-0.5 rounded-full text-xs font-bold ${scoreBg}">${p.smpScore}</span></td>
        <td class="py-2.5 pr-3"><div class="font-semibold text-stone-800 text-xs">${p.siteName || domain}</div><a href="${p.url}" target="_blank" class="text-xs text-green-700 hover:underline">${domain}</a></td>
        <td class="py-2.5 pr-3 text-xs text-stone-600">${p.platform}</td>
        <td class="py-2.5 pr-3 text-xs text-stone-600">${p.pageCount || '—'}</td>
        <td class="py-2.5 pr-3 text-xs text-stone-600">${perf}</td>
        <td class="py-2.5 pr-3 text-xs">${contactHtml}</td>
        <td class="py-2.5 pr-3 text-xs">${flags.join(' ') || '—'}</td>
      </tr>`;
    }).join('');
  }

  // Batch proposal generation
  document.getElementById('pf-propose-btn')!.addEventListener('click', async () => {
    const checked = document.querySelectorAll<HTMLInputElement>('.pf-row-check:checked');
    const urls = Array.from(checked).map(cb => cb.dataset.url).filter(Boolean);
    if (!urls.length) return;

    const btn = document.getElementById('pf-propose-btn') as HTMLButtonElement;
    btn.disabled = true; btn.textContent = `Generating ${urls.length} Proposals...`;
    const statusEl = document.getElementById('pf-propose-status')!;
    statusEl.classList.remove('hidden');
    statusEl.textContent = `Starting ${urls.length} proposal jobs...`;

    try {
      const resp = await fetch('/api/tools-prospect-propose', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ urls }),
      });
      const data = await resp.json();
      if (data.error) throw new Error(data.error);

      const jobs = data.jobs || [];
      const started = jobs.filter((j: any) => j.job_id).length;
      const failed = jobs.filter((j: any) => j.error).length;
      statusEl.innerHTML = `<span class="text-green-700 font-semibold">${started} proposal(s) started.</span>${failed ? ` <span class="text-red-600">${failed} failed to start.</span>` : ''} Check the Proposal tool above to monitor progress.`;
    } catch (err: any) {
      statusEl.innerHTML = `<span class="text-red-600">Error: ${err.message}</span>`;
    }
    btn.disabled = false; btn.textContent = 'Generate Proposals for Selected';
  });

  // Init
  // loadProjects removed
  loadHistory();
  // loadSiteUpdateSites removed — site updates now run via Claude Code commands
}

// ════════════════════════════════════════════════════════════════════════════
// COVER GENERATOR
// ════════════════════════════════════════════════════════════════════════════
function fileToBase64(file: File): Promise<string> {
  return new Promise((resolve, reject) => {
    const reader = new FileReader();
    reader.onload = () => resolve((reader.result as string).split(',')[1]);
    reader.onerror = reject;
    reader.readAsDataURL(file);
  });
}

const coverForm = document.getElementById('cover-form') as HTMLFormElement | null;
if (coverForm) {
  coverForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('cover-btn') as HTMLButtonElement;
    const status = document.getElementById('cover-status')!;
    const spinner = document.getElementById('cover-spinner')!;
    const result = document.getElementById('cover-result')!;
    const errorBox = document.getElementById('cover-error')!;

    btn.disabled = true;
    status.classList.remove('hidden');
    spinner.classList.remove('hidden');
    result.classList.add('hidden');
    errorBox.classList.add('hidden');

    const fd = new FormData(coverForm);

    // Build payload with text fields
    const payload: any = {};
    for (const [key, value] of fd.entries()) {
      if (value instanceof File) continue;
      const v = (value as string).trim();
      if (v) payload[key] = v;
    }
    if (payload.price_usd) payload.price_usd = parseFloat(payload.price_usd);
    if (payload.pages) payload.pages = parseInt(payload.pages, 10);

    // Encode files to base64
    try {
      const front = fd.get('front_cover') as File;
      const headshot = fd.get('headshot') as File;
      const wrap = fd.get('back_painting_wrap') as File;
      payload.front_cover_b64 = await fileToBase64(front);
      payload.headshot_b64 = await fileToBase64(headshot);
      if (wrap && wrap.size > 0) {
        payload.back_painting_wrap_b64 = await fileToBase64(wrap);
      }
    } catch (err: any) {
      spinner.classList.add('hidden');
      errorBox.classList.remove('hidden');
      (document.getElementById('cover-error-text') as HTMLElement).textContent = `File read failed: ${err.message || err}`;
      btn.disabled = false;
      return;
    }

    try {
      const resp = await fetch('/api/tools-cover-generate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = await resp.json();
      spinner.classList.add('hidden');

      if (!resp.ok) {
        errorBox.classList.remove('hidden');
        (document.getElementById('cover-error-text') as HTMLElement).textContent =
          data.error || data.stderr || 'Unknown error';
        btn.disabled = false;
        return;
      }

      // Wire up result block
      (document.getElementById('cover-result-slug') as HTMLElement).textContent = data.slug;
      (document.getElementById('cover-result-spine') as HTMLElement).textContent =
        data.spine_width_in ? `${data.spine_width_in}"` : '—';
      const previewUrl = `/api/tools-cover-file?slug=${encodeURIComponent(data.slug)}&file=${encodeURIComponent(data.version + '-preview.png')}`;
      const pdfUrl = `/api/tools-cover-file?slug=${encodeURIComponent(data.slug)}&file=${encodeURIComponent(data.version + '-kdp.pdf')}`;
      (document.getElementById('cover-result-preview') as HTMLImageElement).src = previewUrl;
      (document.getElementById('cover-result-pdf') as HTMLAnchorElement).href = pdfUrl;
      (document.getElementById('cover-result-png') as HTMLAnchorElement).href = previewUrl;
      result.classList.remove('hidden');
    } catch (err: any) {
      spinner.classList.add('hidden');
      errorBox.classList.remove('hidden');
      (document.getElementById('cover-error-text') as HTMLElement).textContent = err.message || String(err);
    } finally {
      btn.disabled = false;
    }
  });
}
</script>
