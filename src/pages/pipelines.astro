<script>
if (!(window as any).__portalInitialized) {
  (window as any).__portalInitialized = true;

  // ── Project registry ─────────────────────────────────────────
  let allProjects: any[] = [];

  async function loadProjects() {
    try {
      const resp = await fetch('/api/tools-projects');
      allProjects = await resp.json();
    } catch { allProjects = []; }
    populateDropdowns();
  }

  function populateDropdowns() {
    // New Site QA dropdown — only newsite projects
    const nsSel = document.getElementById('ns-qa-project') as HTMLSelectElement;
    if (nsSel) {
      const newsiteProjects = allProjects.filter(p => p.pipeline === 'newsite');
      nsSel.innerHTML = newsiteProjects.length
        ? '<option value="">Select a project…</option>' + newsiteProjects.map(p => `<option value="${p.id}">${p.title} — Phase ${p.phase || '?'}</option>`).join('')
        : '<option value="">No new site projects yet</option>';
    }

  }

  // ── 1. Proposal ──────────────────────────────────────────────
  document.getElementById('proposal-form')!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const url = (document.getElementById('site-url') as HTMLInputElement).value.trim();
    const btn = document.getElementById('proposal-btn') as HTMLButtonElement;
    btn.disabled = true; btn.textContent = 'Generating…';
    document.getElementById('proposal-status')!.classList.remove('hidden');
    document.getElementById('proposal-spinner')!.classList.remove('hidden');
    ['proposal-result','proposal-error'].forEach(id => document.getElementById(id)!.classList.add('hidden'));
    try {
      const resp = await fetch('/api/tools-proposal', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ url }) });
      const start = await resp.json();
      if (start.error) throw new Error(start.error);
      let challengeSetup = false;
      const poll = async (): Promise<void> => {
        await new Promise(r => setTimeout(r, 4000));
        const job = await (await fetch(`/api/tools-proposal-status?job_id=${start.job_id}`)).json();
        if (job.status === 'pending') {
          // Hide challenge UI if it was showing (challenge solved, proposal resumed)
          document.getElementById('proposal-challenge')!.classList.add('hidden');
          document.getElementById('proposal-spinner')!.classList.remove('hidden');
          return poll();
        }
        if (job.status === 'challenge_required') {
          // Show challenge UI
          document.getElementById('proposal-spinner')!.classList.add('hidden');
          document.getElementById('proposal-challenge')!.classList.remove('hidden');
          // Fetch initial screenshot
          try {
            const ss = await (await fetch(`/api/tools-proposal-challenge?job_id=${start.job_id}`)).json();
            if (ss.image) (document.getElementById('challenge-img') as HTMLImageElement).src = ss.image;
          } catch {}
          // Set up click handlers (once)
          if (!challengeSetup) {
            challengeSetup = true;
            const img = document.getElementById('challenge-img') as HTMLImageElement;
            img.addEventListener('click', async (ev) => {
              const rect = img.getBoundingClientRect();
              const scaleX = img.naturalWidth / rect.width;
              const scaleY = img.naturalHeight / rect.height;
              const x = Math.round((ev.clientX - rect.left) * scaleX);
              const y = Math.round((ev.clientY - rect.top) * scaleY);
              document.getElementById('challenge-status-text')!.textContent = 'Sending click...';
              try {
                const resp = await fetch('/api/tools-proposal-challenge', {
                  method: 'POST', headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ job_id: start.job_id, x, y }),
                });
                const result = await resp.json();
                if (result.image) img.src = result.image;
                document.getElementById('challenge-status-text')!.textContent =
                  result.status === 'solved' ? 'Challenge solved! Resuming proposal...' : 'Click sent. Waiting...';
              } catch { document.getElementById('challenge-status-text')!.textContent = 'Click failed — try again.'; }
            });
            document.getElementById('challenge-dismiss')!.addEventListener('click', async () => {
              await fetch('/api/tools-proposal-challenge-dismiss', {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ job_id: start.job_id }),
              });
              document.getElementById('challenge-status-text')!.textContent = 'Dismissed — waiting for abort...';
            });
            document.getElementById('challenge-refresh')!.addEventListener('click', async () => {
              try {
                const ss = await (await fetch(`/api/tools-proposal-challenge?job_id=${start.job_id}`)).json();
                if (ss.image) img.src = ss.image;
              } catch {}
            });
          }
          return poll();
        }
        document.getElementById('proposal-spinner')!.classList.add('hidden');
        document.getElementById('proposal-challenge')!.classList.add('hidden');
        if (job.status === 'failed') {
          document.getElementById('proposal-error')!.classList.remove('hidden');
          document.getElementById('proposal-error-text')!.textContent = job.log || 'Proposal generation failed.';
        } else {
          document.getElementById('proposal-result')!.classList.remove('hidden');
          (document.getElementById('proposal-link') as HTMLAnchorElement).href = job.proposal_url;
        }
        btn.disabled = false; btn.textContent = 'Generate Proposal';
      };
      poll();
    } catch (err: any) {
      document.getElementById('proposal-spinner')!.classList.add('hidden');
      document.getElementById('proposal-error')!.classList.remove('hidden');
      document.getElementById('proposal-error-text')!.textContent = err.message;
      btn.disabled = false; btn.textContent = 'Generate Proposal';
    }
  });

  // ── 2. Bootstrap ─────────────────────────────────────────────
  document.getElementById('build-title')!.addEventListener('input', (e) => {
    const slugEl = document.getElementById('build-slug') as HTMLInputElement;
    if (!slugEl.dataset.manualEdit)
      slugEl.value = (e.target as HTMLInputElement).value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
  });
  document.getElementById('build-slug')!.addEventListener('input', (e) => { (e.target as HTMLInputElement).dataset.manualEdit = '1'; });

  document.getElementById('bootstrap-btn')!.addEventListener('click', async () => {
    const title = (document.getElementById('build-title') as HTMLInputElement).value.trim();
    const slug  = (document.getElementById('build-slug') as HTMLInputElement).value.trim();
    const clientUrl = (document.getElementById('build-client-url') as HTMLInputElement).value.trim();
    if (!title || !slug) { alert('Site Name and Slug are required.'); return; }
    if (!confirm(`Launch Phase 1 build for "${title}" (${slug})?\n\nCreates:\n• GitHub: Spirit-Media-US/${slug}\n• Sanity project\n• Netlify site\n\nThis cannot be undone.`)) return;
    const btn = document.getElementById('bootstrap-btn') as HTMLButtonElement;
    btn.disabled = true; btn.textContent = 'Building…';
    document.getElementById('bootstrap-status')!.classList.remove('hidden');
    document.getElementById('bootstrap-spinner')!.classList.remove('hidden');
    ['bootstrap-result','bootstrap-error'].forEach(id => document.getElementById(id)!.classList.add('hidden'));
    try {
