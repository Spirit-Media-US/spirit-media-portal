  // ── Migration Phase Tracker ─────────────────────────────────
  const PHASE_COLORS: Record<string, string> = {
    complete: 'bg-green-500',
    in_progress: 'bg-rose-600',
    failed: 'bg-red-500',
    pending: 'bg-stone-200',
  };

  async function loadPhaseTracker(projectId: string) {
    const tracker = document.getElementById('mig-tracker')!;
    const bar = document.getElementById('mig-phase-bar')!;
    const detail = document.getElementById('mig-phase-detail')!;
    const advBtn = document.getElementById('mig-advance-btn') as HTMLButtonElement;
    const qaBtn = document.getElementById('mig-qa-btn') as HTMLButtonElement;
    const msg = document.getElementById('mig-advance-msg')!;
    msg.classList.add('hidden');

    if (!projectId) { tracker.classList.add('hidden'); return; }
    tracker.classList.remove('hidden');

    try {
      const resp = await fetch(`/api/tools-migration-phase?project_id=${projectId}`);
      const data = await resp.json();
      if (data.error) { detail.textContent = data.error; bar.innerHTML = ''; return; }

      // Render phase bar
      bar.innerHTML = data.phases.map((p: any) => {
        const color = PHASE_COLORS[p.status] || 'bg-stone-200';
        const active = p.phase === data.current_phase ? 'ring-2 ring-rose-400 ring-offset-1' : '';
        const label = p.status === 'complete' ? '✓' : p.phase;
        return `<div class="flex-1 flex flex-col items-center gap-1">
          <div class="w-8 h-8 rounded-full ${color} ${active} text-white text-xs font-bold flex items-center justify-center">${label}</div>
          <span class="text-[10px] text-stone-500 text-center leading-tight">${p.name}</span>
        </div>`;
      }).join('');

      // Detail text
      const status = data.current_phase_status === 'failed' ? ' (FAILED — fix before advancing)' : '';
      detail.innerHTML = `<strong>Current:</strong> Phase ${data.current_phase} — ${data.current_phase_name}${status}`;

      // Show/hide buttons based on phase
      if (data.current_phase === 7) {
        advBtn.classList.add('hidden');
        qaBtn.classList.remove('hidden');
      } else if (data.current_phase_status === 'complete' && data.current_phase === 9) {
        advBtn.classList.add('hidden');
        qaBtn.classList.add('hidden');
        detail.innerHTML += '<br><strong class="text-green-700">Pipeline complete.</strong>';
      } else {
        advBtn.classList.remove('hidden');
        qaBtn.classList.add('hidden');
        advBtn.disabled = data.current_phase_status === 'failed';
      }
    } catch (err: any) {
      detail.textContent = 'Failed to load phase info.';
    }
  }

