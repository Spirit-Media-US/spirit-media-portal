<script>
if (!(window as any).__portalInitialized) {
  (window as any).__portalInitialized = true;

  // ── Project registry ─────────────────────────────────────────
  let allProjects: any[] = [];

  async function loadProjects() {
    try {
      const resp = await fetch('/api/tools-projects');
      allProjects = await resp.json();
    } catch { allProjects = []; }
    populateDropdowns();
  }

  function populateDropdowns() {
    // Migration tracker dropdown
    const migSel = document.getElementById('mig-tracker-project') as HTMLSelectElement;
    if (migSel) {
      const migProjects = allProjects.filter(p => p.pipeline === 'migration' || !p.pipeline);
      migSel.innerHTML = '<option value="">Select a migration project…</option>' +
        migProjects.map(p => `<option value="${p.id}">${p.title} — Phase ${p.phase || '?'}: ${p.phase_name || 'unknown'}</option>`).join('');
    }

