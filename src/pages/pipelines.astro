    btn.disabled = true; btn.textContent = 'Generating…';

    const statusEl = document.getElementById('saudit-status')!;
    const spinner = document.getElementById('saudit-spinner')!;
    const statusText = document.getElementById('saudit-status-text')!;
    statusEl.classList.remove('hidden');
    spinner.classList.remove('hidden');
    ['saudit-result', 'saudit-error'].forEach(id => document.getElementById(id)!.classList.add('hidden'));

    try {
      const start = await (await fetch('/api/tools-site-audit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ url, repo_slug: repoSlug, site_title: title }),
      })).json();
      if (start.error) throw new Error(start.error);

      const poll = async (): Promise<void> => {
        await new Promise(r => setTimeout(r, 6000));
        const job = await (await fetch(`/api/tools-site-audit?job_id=${start.job_id}`)).json();
        if (['pending', 'auditing', 'generating'].includes(job.status)) {
          statusText.textContent = job.message || `${job.status}…`;
          return poll();
        }
        spinner.classList.add('hidden');
        if (job.status === 'failed') {
          document.getElementById('saudit-error')!.classList.remove('hidden');
          document.getElementById('saudit-error-text')!.textContent = job.error || 'Unknown error';
        } else {
          document.getElementById('saudit-result')!.classList.remove('hidden');
          const link = document.getElementById('saudit-doc-url') as HTMLAnchorElement;
          link.href = job.doc_url;
          document.getElementById('saudit-doc-title')!.textContent = job.doc_title || '';
        }
        btn.disabled = false; btn.textContent = 'Generate Site Audit Report';
      };
      poll();
    } catch (err: unknown) {
      spinner.classList.add('hidden');
      document.getElementById('saudit-error')!.classList.remove('hidden');
      document.getElementById('saudit-error-text')!.textContent = err instanceof Error ? err.message : 'Unknown error';
      btn.disabled = false; btn.textContent = 'Generate Site Audit Report';
    }
  });

  // Init
  loadProjects();
  loadTemplates();
  loadHistory();
  loadSiteUpdateSites();
}
</script>
