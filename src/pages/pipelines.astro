---
import PortalLayout from "../layouts/PortalLayout.astro";
---

<PortalLayout title="Pipelines">
  <div class="max-w-3xl">
    <h1 class="text-4xl font-bold mb-2">Pipelines</h1>
    <p class="text-stone-600 mb-10">Automated tools organized by department.</p>

    <!-- ══════════════════════════════════════════════════════════
         PRE-SALE — PROPOSAL GENERATOR — amber
    ═══════════════════════════════════════════════════════════ -->
    <div class="mb-12 bg-green-50 rounded-2xl border border-green-200 p-8">
      <div class="flex items-center gap-3 mb-4">
        <span class="inline-block px-3 py-1 rounded-full bg-green-200 text-green-800 text-xs font-bold uppercase tracking-widest">Pre-Sale</span>
      </div>

      <div class="bg-white rounded-2xl border border-green-200 p-8 shadow-sm">
        <h2 class="text-2xl font-bold mb-1">Website Migration Proposal</h2>
        <p class="text-stone-500 text-sm mb-6">Enter the client's current site URL. Generates the Website Modernization Proposal (Google Doc). Sales tool only — when the sale closes, use Start Migration below.</p>
        <form id="proposal-form" class="space-y-4">
          <input type="url" id="site-url" required placeholder="https://clientsite.com"
            class="w-full border border-stone-300 rounded-lg px-4 py-3 text-stone-800 placeholder-stone-400 focus:outline-none focus:ring-2 focus:ring-green-300 text-base" />
          <button type="submit" id="proposal-btn"
            class="w-full bg-green-700 hover:bg-green-800 text-white font-semibold py-3 px-6 rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
            Generate Proposal
          </button>
        </form>
        <div id="proposal-status" class="hidden mt-5">
          <div id="proposal-spinner" class="hidden flex items-center gap-3 text-stone-600 text-sm">
            <svg class="animate-spin h-4 w-4 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path></svg>
            <span>Auditing site and building proposal — 2–4 minutes…</span>
          </div>
          <div id="proposal-result" class="hidden p-5 bg-green-50 border border-green-200 rounded-xl space-y-2">
            <p class="text-sm font-bold text-green-800">Proposal ready!</p>
            <a id="proposal-link" href="#" target="_blank" rel="noopener noreferrer" class="block text-green-700 underline font-medium text-sm">Open Proposal →</a>
            <p class="text-xs text-stone-500 pt-1">When the sale closes, start Phase 1 in the Migration Pipeline below.</p>
          </div>
          <div id="proposal-error" class="hidden p-4 bg-red-50 border border-red-200 rounded-xl">
            <p class="text-sm font-bold text-red-800 mb-1">Error</p>
            <p id="proposal-error-text" class="text-sm text-red-700 font-mono whitespace-pre-wrap"></p>
          </div>
          <div id="proposal-challenge" class="hidden p-6 bg-amber-50 border border-amber-200 rounded-xl">
            <p class="text-sm font-bold text-amber-800 mb-2">Cloudflare Verification Required</p>
            <p class="text-xs text-stone-600 mb-3">This site requires human verification. Click the CAPTCHA checkbox in the image below to proceed.</p>
            <div class="relative inline-block cursor-pointer border border-stone-300 rounded-lg overflow-hidden">
              <img id="challenge-img" src="" alt="Cloudflare challenge" class="max-w-full" style="max-height: 500px;" />
            </div>
            <div class="mt-3 flex gap-3">
              <button id="challenge-refresh" class="text-xs text-amber-700 underline hover:text-amber-900">Refresh Screenshot</button>
              <button id="challenge-dismiss" class="text-xs text-red-600 underline hover:text-red-800">Skip (abort proposal)</button>
            </div>
            <p id="challenge-status-text" class="text-xs text-stone-500 mt-2">Click on the checkbox in the image above.</p>
          </div>
        </div>
      </div>
    </div><!-- end Pre-Sale -->

    <!-- ══════════════════════════════════════════════════════════
         WEBSITE MIGRATION — rose
    ═══════════════════════════════════════════════════════════ -->
    <div class="mb-12 bg-rose-50 rounded-2xl border border-rose-200 p-8">
      <div class="flex items-center gap-3 mb-4">
        <span class="inline-block px-3 py-1 rounded-full bg-rose-200 text-rose-800 text-xs font-bold uppercase tracking-widest">Website Migration</span>
      </div>
      <p class="text-stone-600 text-sm mb-6">The Transformation System — 9 phases. <a href="/playbook" class="text-rose-700 hover:underline font-semibold">Read the full protocol on the Playbook</a> before your first migration.</p>

      <!-- How It Works -->
      <div class="bg-white border border-rose-200 rounded-lg p-5 mb-6">
        <p class="font-bold text-stone-800 text-sm mb-3">How it works</p>
        <ol class="list-decimal ml-4 space-y-2 text-sm text-stone-600">
          <li><strong>Start here</strong> — fill in the form below and click Start Migration. This creates the GitHub repo, Sanity project, and Netlify site.</li>
          <li><strong>Go to Bethel</strong> — when it's done, you'll see the next command. SSH in and run it:<br/>
            <code class="bg-white border border-stone-200 px-2 py-1 rounded text-xs font-mono mt-1 inline-block">cd ~/Sites/&lt;slug&gt; && claude</code></li>
          <li><strong>Say "continue migration"</strong> — Claude reads the protocol, checks which phase you're on, and does the work. It tells you when to preview the site and what to check.</li>
          <li><strong>Preview when told</strong> — Claude starts the dev server and gives you the URL. Compare against the original site.</li>
          <li><strong>Say "continue"</strong> — Claude advances to the next phase. If a session ends, start a new one and say "continue migration" again. It picks up where it left off.</li>
        </ol>
      </div>

      <!-- Start Migration -->
      <div class="bg-white rounded-2xl border border-rose-200 p-8 shadow-sm">
        <h2 class="text-2xl font-bold mb-1">Start Migration</h2>
        <p class="text-stone-500 text-sm mb-6">Creates GitHub repo, Sanity project, and Netlify site. Clones the repo to Bethel and sets up the scaffold.</p>
        <div class="space-y-4">
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label for="build-title" class="block text-sm font-semibold text-stone-700 mb-1">Site Name</label>
              <input id="build-title" type="text" placeholder="Global Hope India"
                class="w-full border border-stone-300 rounded-lg px-4 py-2.5 text-stone-800 focus:outline-none focus:ring-2 focus:ring-rose-300" />
            </div>
            <div>
              <label for="build-slug" class="block text-sm font-semibold text-stone-700 mb-1">Slug</label>
              <input id="build-slug" type="text" placeholder="global-hope-india"
                class="w-full border border-stone-300 rounded-lg px-4 py-2.5 text-stone-800 font-mono focus:outline-none focus:ring-2 focus:ring-rose-300" />
            </div>
          </div>
          <div>
            <label for="build-client-url" class="block text-sm font-semibold text-stone-700 mb-1">Client's Current URL</label>
            <input id="build-client-url" type="url" placeholder="https://globalhopeindia.org"
              class="w-full border border-stone-300 rounded-lg px-4 py-2.5 text-stone-800 focus:outline-none focus:ring-2 focus:ring-rose-300" />
          </div>
          <button id="bootstrap-btn"
            class="w-full bg-rose-700 hover:bg-rose-800 text-white font-semibold py-3 px-6 rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
            Start Migration
          </button>
        </div>
        <div id="bootstrap-status" class="hidden mt-5">
          <div id="bootstrap-spinner" class="hidden flex items-center gap-3 text-stone-600 text-sm">
            <svg class="animate-spin h-4 w-4 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path></svg>
            <span>Creating infrastructure — GitHub, Sanity, Netlify… (~2 min)</span>
          </div>
          <div id="bootstrap-result" class="hidden p-5 bg-green-50 border border-green-200 rounded-xl space-y-3">
            <p class="text-sm font-bold text-green-800">Ready! Infrastructure created.</p>
            <div id="bootstrap-links" class="space-y-1.5"></div>
            <div class="bg-white border border-green-200 rounded-lg p-4 mt-3">
              <p class="text-sm font-bold text-stone-800 mb-2">Next step:</p>
              <code class="block bg-stone-100 px-3 py-2 rounded text-sm font-mono text-stone-700">cd ~/Sites/<span id="bootstrap-slug-echo"></span> && claude</code>
              <p class="text-xs text-stone-500 mt-2">Then say: <strong>"continue migration"</strong></p>
            </div>
          </div>
          <div id="bootstrap-error" class="hidden p-4 bg-red-50 border border-red-200 rounded-xl">
            <p class="text-sm font-bold text-red-800 mb-1">Error</p>
            <p id="bootstrap-error-text" class="text-sm text-red-700 font-mono whitespace-pre-wrap"></p>
          </div>
        </div>
      </div>

    </div><!-- end Website Migration -->

    <!-- ══════════════════════════════════════════════════════════
         NEW SITE BUILD — teal
    ═══════════════════════════════════════════════════════════ -->
    <div class="mb-12 bg-blue-50 rounded-2xl border border-blue-200 p-8">
      <div class="flex items-center gap-3 mb-4">
        <span class="inline-block px-3 py-1 rounded-full bg-blue-200 text-blue-800 text-xs font-bold uppercase tracking-widest">New Site Build</span>
      </div>
      <p class="text-stone-600 text-sm mb-6">The Build System — 9 phases. <a href="/playbook" class="text-blue-700 hover:underline font-semibold">Read the full protocol on the Playbook</a> before your first new site build.</p>

      <!-- How It Works -->
      <div class="bg-white border border-blue-200 rounded-lg p-5 mb-6">
        <p class="font-bold text-stone-800 text-sm mb-3">How it works</p>
        <ol class="list-decimal ml-4 space-y-2 text-sm text-stone-600">
          <li><strong>Start here</strong> — fill in the form below and click Start New Site Build.</li>
          <li><strong>Go to Bethel</strong> — when it's done, you'll see the command:<br/>
            <code class="bg-white border border-stone-200 px-2 py-1 rounded text-xs font-mono mt-1 inline-block">cd ~/Sites/&lt;slug&gt; && claude</code></li>
          <li><strong>Say "continue newsite"</strong> — Claude starts Phase 1 (Discovery &amp; Brand), researches the client, and generates a creative brief.</li>
          <li><strong>Preview when told</strong> — Claude starts the dev server and gives you the URL.</li>
          <li><strong>Say "continue"</strong> — Claude advances to the next phase. If a session ends, say "continue newsite" again.</li>
        </ol>
      </div>

      <!-- Start New Site Build -->
      <div class="bg-white rounded-2xl border border-blue-200 p-8 shadow-sm">
        <h2 class="text-2xl font-bold mb-1">Start New Site Build</h2>
        <p class="text-stone-500 text-sm mb-6">Creates GitHub repo, Sanity project, and Netlify site. No existing site URL needed.</p>
        <div class="space-y-4">
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label for="ns-build-title" class="block text-sm font-semibold text-stone-700 mb-1">Site Name</label>
              <input id="ns-build-title" type="text" placeholder="Global Hope India"
                class="w-full border border-stone-300 rounded-lg px-4 py-2.5 text-stone-800 focus:outline-none focus:ring-2 focus:ring-blue-300" />
            </div>
            <div>
              <label for="ns-build-slug" class="block text-sm font-semibold text-stone-700 mb-1">Slug</label>
              <input id="ns-build-slug" type="text" placeholder="global-hope-india"
                class="w-full border border-stone-300 rounded-lg px-4 py-2.5 text-stone-800 font-mono focus:outline-none focus:ring-2 focus:ring-blue-300" />
            </div>
          </div>
          <button id="ns-bootstrap-btn"
            class="w-full bg-blue-700 hover:bg-blue-800 text-white font-semibold py-3 px-6 rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
            Start New Site Build
          </button>
        </div>
        <div id="ns-bootstrap-status" class="hidden mt-5">
          <div id="ns-bootstrap-spinner" class="hidden flex items-center gap-3 text-stone-600 text-sm">
            <svg class="animate-spin h-4 w-4 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path></svg>
            <span>Creating infrastructure — GitHub, Sanity, Netlify... (~2 min)</span>
          </div>
          <div id="ns-bootstrap-result" class="hidden p-5 bg-green-50 border border-green-200 rounded-xl space-y-3">
            <p class="text-sm font-bold text-green-800">Ready! Infrastructure created.</p>
            <div id="ns-bootstrap-links" class="space-y-1.5"></div>
            <div class="bg-white border border-green-200 rounded-lg p-4 mt-3">
              <p class="text-sm font-bold text-stone-800 mb-2">Next step:</p>
              <code class="block bg-stone-100 px-3 py-2 rounded text-sm font-mono text-stone-700">cd ~/Sites/<span id="ns-bootstrap-slug-echo"></span> && claude</code>
              <p class="text-xs text-stone-500 mt-2">Then say: <strong>"continue newsite"</strong></p>
            </div>
          </div>
          <div id="ns-bootstrap-error" class="hidden p-4 bg-red-50 border border-red-200 rounded-xl">
            <p class="text-sm font-bold text-red-800 mb-1">Error</p>
            <p id="ns-bootstrap-error-text" class="text-sm text-red-700 font-mono whitespace-pre-wrap"></p>
          </div>
        </div>
      </div>

    </div><!-- end New Site Build -->

    <!-- ══════════════════════════════════════════════════════════
         SHARED WEB DEV TOOLS — stone
    ═══════════════════════════════════════════════════════════ -->
    <div class="mb-12 bg-violet-50 rounded-2xl border border-violet-200 p-8">
      <div class="flex items-center gap-3 mb-4">
        <span class="inline-block px-3 py-1 rounded-full bg-violet-200 text-violet-800 text-xs font-bold uppercase tracking-widest">Shared Tools</span>
      </div>
      <p class="text-stone-600 text-sm mb-6">Work with any SMP site — migration or new build.</p>

      <!-- Site Updates -->
      <div class="bg-white rounded-2xl border border-violet-200 p-8 mb-6 shadow-sm">
        <h2 class="text-2xl font-bold mb-1">Request a Site Update</h2>
        <p class="text-stone-500 text-sm mb-6">Select a site, describe the change — Claude makes the edit and pushes to dev.</p>
        <form id="site-update-form" class="space-y-4">
          <div>
            <label for="site-update-site" class="block text-sm font-semibold text-stone-700 mb-2">Site</label>
            <select id="site-update-site" name="site_slug" required
              class="w-full border border-stone-300 rounded-lg px-4 py-3 text-stone-800 focus:outline-none focus:ring-2 focus:ring-violet-300 bg-white">
              <option value="">Loading sites…</option>
            </select>
          </div>
          <div>
            <label for="site-update-request" class="block text-sm font-semibold text-stone-700 mb-2">What would you like to change?</label>
            <textarea id="site-update-request" name="request_text" required rows="5"
              placeholder='e.g. Change the hero headline to "Walking in Freedom" and update the button to say "Start Your Journey"'
              class="w-full border border-stone-300 rounded-lg px-4 py-3 text-stone-800 placeholder-stone-400 focus:outline-none focus:ring-2 focus:ring-violet-300 resize-y text-sm"></textarea>
            <p class="text-xs text-stone-400 mt-1">Be specific. The more detail you give, the better the result.</p>
          </div>
          <button type="submit" id="site-update-btn"
            class="w-full bg-violet-700 hover:bg-violet-800 text-white font-semibold py-3 rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
            Submit Update Request
          </button>
        </form>
        <div id="site-update-status" class="hidden mt-5">
          <div id="site-update-spinner" class="hidden flex items-center gap-3 text-stone-500 text-sm">
            <svg class="animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path></svg>
            <span id="site-update-status-text">Sending to Claude…</span>
          </div>
          <div id="site-update-result" class="hidden p-5 bg-green-50 border border-green-200 rounded-lg space-y-2">
            <p class="font-semibold text-green-800 text-sm">Update complete — PR ready for review.</p>
            <a id="site-update-pr-url" href="#" target="_blank" rel="noopener noreferrer" class="block text-sm text-green-700 underline font-medium break-all"></a>
            <a id="site-update-preview-url" href="#" target="_blank" rel="noopener noreferrer" class="block text-xs text-green-600 underline break-all"></a>
          </div>
          <div id="site-update-ambiguous" class="hidden p-5 bg-amber-50 border border-amber-200 rounded-lg">
            <p class="font-semibold text-amber-800 text-sm mb-1">We need more detail</p>
            <p id="site-update-ambiguous-text" class="text-amber-700 text-sm"></p>
          </div>
          <div id="site-update-error" class="hidden p-4 bg-red-50 border border-red-200 rounded-lg">
            <p class="font-semibold text-red-800 text-sm mb-1">Something went wrong</p>
            <p id="site-update-error-text" class="text-red-700 text-sm"></p>
          </div>
        </div>
      </div>
      <!-- Pre-Launch QA -->
      <div class="bg-white rounded-2xl border border-violet-200 p-8 mb-6 shadow-sm">
        <h2 class="text-2xl font-bold mb-1">Pre-Launch QA</h2>
        <p class="text-stone-500 text-sm mb-6">8 code scans + build gate. Generates a Google Doc report. Run as many times as needed.</p>
        <form id="plqa-pre-form" class="space-y-4">
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label for="plqa-pre-slug" class="block text-sm font-semibold text-stone-700 mb-1">Repo Slug</label>
              <input type="text" id="plqa-pre-slug" required placeholder="scripture-alive"
                class="w-full border border-stone-300 rounded-lg px-4 py-3 text-stone-800 placeholder-stone-400 focus:outline-none focus:ring-2 focus:ring-violet-300" />
            </div>
            <div>
              <label for="plqa-pre-title" class="block text-sm font-semibold text-stone-700 mb-1">Site Name</label>
              <input type="text" id="plqa-pre-title" required placeholder="Scripture Alive"
                class="w-full border border-stone-300 rounded-lg px-4 py-3 text-stone-800 placeholder-stone-400 focus:outline-none focus:ring-2 focus:ring-violet-300" />
            </div>
          </div>
          <button type="submit" id="plqa-pre-btn"
            class="w-full bg-violet-700 hover:bg-violet-800 text-white font-semibold py-3 px-6 rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
            Run Pre-Launch QA
          </button>
        </form>
        <div id="plqa-pre-status" class="hidden mt-5">
          <div id="plqa-pre-spinner" class="hidden flex items-center gap-3 text-stone-500 text-sm">
            <svg class="animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path></svg>
            <span id="plqa-pre-status-text">Running 8 scans + build gate...</span>
          </div>
          <div id="plqa-pre-result" class="hidden p-5 bg-green-50 border border-green-200 rounded-lg space-y-2">
            <p id="plqa-pre-summary" class="font-semibold text-sm"></p>
            <a id="plqa-pre-doc-url" href="#" target="_blank" rel="noopener noreferrer"
              class="block text-green-700 underline font-medium text-sm">Open Report →</a>
          </div>
          <div id="plqa-pre-error" class="hidden p-4 bg-red-50 border border-red-200 rounded-lg">
            <p class="font-semibold text-red-800 text-sm">Error</p>
            <p id="plqa-pre-error-text" class="text-red-700 text-sm font-mono mt-1"></p>
          </div>
        </div>
      </div>

      <!-- Post-Launch QA -->
      <div class="bg-white rounded-2xl border border-violet-200 p-8 mb-6 shadow-sm">
        <h2 class="text-2xl font-bold mb-1">Post-Launch QA</h2>
        <p class="text-stone-500 text-sm mb-6">Lighthouse + SEO + accessibility on the live URL. Auto-fixes what it can, generates a Google Doc report.</p>
        <form id="plqa-form" class="space-y-4">
          <div>
            <label for="plqa-url" class="block text-sm font-semibold text-stone-700 mb-1">Live URL</label>
            <input type="url" id="plqa-url" required placeholder="https://thekohlergroup.net"
              class="w-full border border-stone-300 rounded-lg px-4 py-3 text-stone-800 placeholder-stone-400 focus:outline-none focus:ring-2 focus:ring-violet-300" />
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label for="plqa-slug" class="block text-sm font-semibold text-stone-700 mb-1">Repo Slug</label>
              <input type="text" id="plqa-slug" required placeholder="the-kohler-group"
                class="w-full border border-stone-300 rounded-lg px-4 py-3 text-stone-800 placeholder-stone-400 focus:outline-none focus:ring-2 focus:ring-violet-300" />
            </div>
            <div>
              <label for="plqa-title" class="block text-sm font-semibold text-stone-700 mb-1">Site Name</label>
              <input type="text" id="plqa-title" required placeholder="The Kohler Group"
                class="w-full border border-stone-300 rounded-lg px-4 py-3 text-stone-800 placeholder-stone-400 focus:outline-none focus:ring-2 focus:ring-violet-300" />
            </div>
          </div>
          <button type="submit" id="plqa-btn"
            class="w-full bg-violet-700 hover:bg-violet-800 text-white font-semibold py-3 px-6 rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
            Run Post-Launch QA
          </button>
        </form>
        <div id="plqa-status" class="hidden mt-6 space-y-4">
          <div id="plqa-spinner" class="hidden flex items-center gap-3 text-stone-500 text-sm">
            <svg class="animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path></svg>
            <span id="plqa-status-text">Starting audit…</span>
          </div>
          <div id="plqa-result" class="hidden space-y-4">
            <div class="grid grid-cols-2 gap-3">
              <div class="bg-stone-50 rounded-xl p-4 text-center border border-stone-200">
                <p class="text-xs font-bold uppercase tracking-widest text-stone-400 mb-1">Mobile</p>
                <p id="plqa-mobile-score" class="text-3xl font-bold"></p>
                <p class="text-xs text-stone-400 mt-1">Performance</p>
              </div>
              <div class="bg-stone-50 rounded-xl p-4 text-center border border-stone-200">
                <p class="text-xs font-bold uppercase tracking-widest text-stone-400 mb-1">Desktop</p>
                <p id="plqa-desktop-score" class="text-3xl font-bold"></p>
                <p class="text-xs text-stone-400 mt-1">Performance</p>
              </div>
            </div>
            <div id="plqa-checks" class="space-y-1.5"></div>
            <div id="plqa-fixes-box" class="hidden bg-green-50 border border-green-200 rounded-lg p-4">
