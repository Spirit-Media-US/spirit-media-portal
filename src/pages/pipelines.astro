  // ── 4. Post-Launch QA ─────────────────────────────────────────
  function scoreColor(n: number): string {
    if (n >= 90) return 'text-green-600';
    if (n >= 50) return 'text-amber-500';
    return 'text-red-600';
  }

  function renderChecks(pages: any[]): void {
    const container = document.getElementById('plqa-checks')!;
    const allIssues: any[] = [];
    const allPasses: string[] = [];
    for (const p of pages) {
      for (const i of (p.issues || [])) allIssues.push({ ...i, page: p.url });
      for (const pass of (p.passes || [])) allPasses.push(pass.item || pass);
    }
    const uniquePasses = [...new Set(allPasses)];
    const html = [
      ...allIssues.map(i => {
        const color = i.severity === 'critical' ? 'text-red-700 bg-red-50 border-red-200'
          : i.severity === 'high' ? 'text-amber-700 bg-amber-50 border-amber-200'
          : 'text-yellow-700 bg-yellow-50 border-yellow-200';
        const badge = i.fix === 'flag_only' ? '⚑ flag' : '⚙ auto-fix';
        return `<div class="flex items-start gap-2 px-3 py-2 rounded-lg border text-xs ${color}">
          <span class="shrink-0">✗</span>
          <span class="flex-1"><strong>${i.category}</strong> — ${i.item}${i.detail ? ': ' + i.detail : ''}</span>
          <span class="shrink-0 opacity-70">${badge}</span>
        </div>`;
      }),
      ...uniquePasses.map(p => `<div class="flex items-center gap-2 px-3 py-2 rounded-lg text-xs text-green-700 bg-green-50 border border-green-200">
        <span>✓</span><span>${p}</span></div>`),
    ].join('');
    container.innerHTML = html || '<p class="text-sm text-stone-500">No checks returned.</p>';
  }

