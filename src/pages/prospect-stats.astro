---
import baked from "../data/prospect-stats.json";
import PortalLayout from "../layouts/PortalLayout.astro";

const s = baked.summary ?? {
	total: 0,
	opened: 0,
	clicked: 0,
	replied: 0,
	openRate: "—",
	clickRate: "—",
};
const prospects = baked.prospects ?? [];
const builtAt = baked.builtAt ?? "";
const stale = baked.stale ?? false;
---

<PortalLayout title="Prospect Stats">
  <div class="max-w-6xl">
    <h1 class="text-4xl font-bold mb-2">Prospect Stats</h1>
    <p class="text-stone-600 mb-2">Email outreach tracking — opens, clicks, follow-ups, and replies.</p>

    <!-- Last built + refresh status -->
    <div class="flex items-center gap-3 text-xs text-stone-500 mb-6">
      <span>Last built: <span id="built-at" data-iso={builtAt}>—</span></span>
      {stale && <span class="px-2 py-0.5 rounded-full bg-amber-100 text-amber-800 font-semibold">Stale (last build failed to refresh data)</span>}
    </div>

    <!-- Summary Cards -->
    <div id="summary-cards" class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
      <div class="bg-white rounded-xl border border-stone-200 p-5 text-center">
        <p class="text-3xl font-bold text-stone-800">{s.total}</p>
        <p class="text-xs text-stone-500 font-semibold uppercase tracking-wider mt-1">Total Sent</p>
      </div>
      <div class="bg-white rounded-xl border border-stone-200 p-5 text-center">
        <p class="text-3xl font-bold text-blue-700">{s.opened}</p>
        <p class="text-xs text-stone-500 font-semibold uppercase tracking-wider mt-1">Opened <span class="text-stone-400">({s.openRate})</span></p>
      </div>
      <div class="bg-white rounded-xl border border-stone-200 p-5 text-center">
        <p class="text-3xl font-bold text-green-700">{s.clicked}</p>
        <p class="text-xs text-stone-500 font-semibold uppercase tracking-wider mt-1">Clicked <span class="text-stone-400">({s.clickRate})</span></p>
      </div>
      <div class="bg-white rounded-xl border border-stone-200 p-5 text-center">
        <p class="text-3xl font-bold text-amber-600">{s.replied}</p>
        <p class="text-xs text-stone-500 font-semibold uppercase tracking-wider mt-1">Replied</p>
      </div>
    </div>

    <!-- Filters -->
    <div class="flex items-center gap-3 mb-4 flex-wrap">
      <div class="relative flex-1 min-w-[200px]">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-stone-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
        </svg>
        <input id="search" type="search" placeholder="Search by name, email, or URL..."
          class="w-full pl-9 pr-4 py-2 rounded-lg border border-stone-300 bg-stone-50 text-sm text-stone-700 placeholder-stone-400 focus:outline-none focus:ring-2 focus:ring-blue-300" />
      </div>
      <select id="filter-status" class="border border-stone-300 rounded-lg px-3 py-2 text-sm text-stone-700 bg-white">
        <option value="all">All Status</option>
        <option value="opened">Opened</option>
        <option value="clicked">Clicked</option>
        <option value="replied">Replied</option>
        <option value="no-engagement">No Engagement</option>
      </select>
      <button id="refresh-btn" class="border border-stone-300 rounded-lg px-4 py-2 text-sm font-semibold text-stone-600 hover:bg-stone-100 transition-colors inline-flex items-center gap-2">
        <svg id="refresh-spinner" class="hidden animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path></svg>
        <span id="refresh-label">Refresh</span>
      </button>
    </div>

    <!-- Refresh status line -->
    <div id="refresh-status" class="hidden mb-3 text-sm px-3 py-2 rounded-lg"></div>

    <!-- Results count -->
    <p id="results-count" class="text-xs text-stone-400 mb-3"></p>

    <!-- Table -->
    <div id="table-wrap" class="bg-white rounded-xl border border-stone-200 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-stone-50 border-b border-stone-200 text-left">
              <th class="px-4 py-3 font-semibold text-stone-600 cursor-pointer hover:text-stone-900" data-sort="siteName">Name</th>
              <th class="px-4 py-3 font-semibold text-stone-600 cursor-pointer hover:text-stone-900" data-sort="email">Email</th>
              <th class="px-4 py-3 font-semibold text-stone-600 text-center cursor-pointer hover:text-stone-900" data-sort="openCount">Opens</th>
              <th class="px-4 py-3 font-semibold text-stone-600 text-center cursor-pointer hover:text-stone-900" data-sort="clickCount">Clicks</th>
              <th class="px-4 py-3 font-semibold text-stone-600 text-center cursor-pointer hover:text-stone-900" data-sort="followUpsSent">Follow-ups</th>
              <th class="px-4 py-3 font-semibold text-stone-600 cursor-pointer hover:text-stone-900" data-sort="sentAt">Sent</th>
              <th class="px-4 py-3 font-semibold text-stone-600">Status</th>
              <th class="px-4 py-3 font-semibold text-stone-600">Links</th>
            </tr>
          </thead>
          <tbody id="table-body"></tbody>
        </table>
      </div>
    </div>

    <!-- Pagination -->
    <div id="pagination" class="mt-4 flex items-center justify-center gap-2"></div>

    <script id="baked-data" type="application/json" set:html={JSON.stringify(prospects)}></script>
  </div>
</PortalLayout>

<script>
  const PER_PAGE = 25;
  const allProspects: any[] = JSON.parse(document.getElementById('baked-data')?.textContent || '[]');
  let filtered: any[] = [...allProspects];
  let currentPage = 1;
  let sortField = 'sentAt';
  let sortDir: 'asc' | 'desc' = 'desc';

  // Format "Last built" timestamp
  const builtEl = document.getElementById('built-at');
  if (builtEl?.dataset.iso) {
    const d = new Date(builtEl.dataset.iso);
    const mins = Math.max(0, Math.floor((Date.now() - d.getTime()) / 60000));
    let ago: string;
    if (mins < 1) ago = 'just now';
    else if (mins < 60) ago = `${mins} min ago`;
    else if (mins < 1440) ago = `${Math.floor(mins / 60)} hr ago`;
    else ago = `${Math.floor(mins / 1440)} day(s) ago`;
    builtEl.textContent = `${d.toLocaleString()} (${ago})`;
  } else {
    builtEl!.textContent = '(never)';
  }

  function applyFilters() {
    const q = (document.getElementById('search') as HTMLInputElement).value.toLowerCase().trim();
    const status = (document.getElementById('filter-status') as HTMLSelectElement).value;

    filtered = allProspects.filter(p => {
      const matchQ = !q ||
        p.siteName.toLowerCase().includes(q) ||
        p.email.toLowerCase().includes(q) ||
        (p.url || '').toLowerCase().includes(q);

      let matchStatus = true;
      if (status === 'opened') matchStatus = p.openCount > 0;
      else if (status === 'clicked') matchStatus = p.clickCount > 0;
      else if (status === 'replied') matchStatus = p.replied;
      else if (status === 'no-engagement') matchStatus = p.openCount === 0 && p.clickCount === 0 && !p.replied;

      return matchQ && matchStatus;
    });

    filtered.sort((a, b) => {
      let av = a[sortField] ?? '';
      let bv = b[sortField] ?? '';
      if (typeof av === 'number') return sortDir === 'asc' ? av - bv : bv - av;
      av = String(av).toLowerCase();
      bv = String(bv).toLowerCase();
      return sortDir === 'asc' ? av.localeCompare(bv) : bv.localeCompare(av);
    });

    currentPage = 1;
    render();
  }

  function render() {
    const start = (currentPage - 1) * PER_PAGE;
    const page = filtered.slice(start, start + PER_PAGE);

    document.getElementById('results-count')!.textContent = filtered.length === 0
      ? 'No prospects match your filters.'
      : `Showing ${start + 1}–${Math.min(start + PER_PAGE, filtered.length)} of ${filtered.length} prospects`;

    const tbody = document.getElementById('table-body')!;
    tbody.innerHTML = page.map(p => {
      const sentDate = p.sentAt ? new Date(p.sentAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) : '—';
      const statusBadge = p.replied
        ? '<span class="px-2 py-0.5 rounded-full bg-amber-100 text-amber-800 text-xs font-semibold">Replied</span>'
        : p.clickCount > 0
        ? '<span class="px-2 py-0.5 rounded-full bg-green-100 text-green-800 text-xs font-semibold">Clicked</span>'
        : p.openCount > 0
        ? '<span class="px-2 py-0.5 rounded-full bg-blue-100 text-blue-800 text-xs font-semibold">Opened</span>'
        : '<span class="px-2 py-0.5 rounded-full bg-stone-100 text-stone-500 text-xs font-semibold">Sent</span>';

      const links = [];
      if (p.proposalUrl) links.push(`<a href="${p.proposalUrl}" target="_blank" rel="noopener noreferrer" class="text-blue-600 hover:underline">Proposal</a>`);
      if (p.url) links.push(`<a href="${p.url}" target="_blank" rel="noopener noreferrer" class="text-stone-500 hover:underline">Site</a>`);

      return `<tr class="border-b border-stone-100 hover:bg-stone-50">
        <td class="px-4 py-3 font-medium text-stone-800 max-w-[200px] truncate" title="${p.siteName}">${p.siteName || '—'}</td>
        <td class="px-4 py-3 text-stone-600 max-w-[200px] truncate" title="${p.email}">${p.email}</td>
        <td class="px-4 py-3 text-center ${p.openCount > 0 ? 'text-blue-700 font-semibold' : 'text-stone-400'}">${p.openCount}</td>
        <td class="px-4 py-3 text-center ${p.clickCount > 0 ? 'text-green-700 font-semibold' : 'text-stone-400'}">${p.clickCount}</td>
        <td class="px-4 py-3 text-center text-stone-600">${p.followUpsSent}/6</td>
        <td class="px-4 py-3 text-stone-500">${sentDate}</td>
        <td class="px-4 py-3">${statusBadge}</td>
        <td class="px-4 py-3 space-x-2 text-xs">${links.join(' · ')}</td>
      </tr>`;
    }).join('');

    renderPagination();
  }

  function renderPagination() {
    const el = document.getElementById('pagination')!;
    const totalPages = Math.ceil(filtered.length / PER_PAGE);
    if (totalPages <= 1) { el.innerHTML = ''; return; }

    let html = '';
    html += `<button data-page="${currentPage - 1}" ${currentPage === 1 ? 'disabled' : ''} class="px-3 py-1.5 rounded-lg border text-xs font-semibold transition-colors ${currentPage === 1 ? 'border-stone-200 text-stone-300 cursor-not-allowed' : 'border-stone-300 text-stone-600 hover:bg-stone-100'}">Prev</button>`;
    for (let i = 1; i <= totalPages; i++) {
      html += `<button data-page="${i}" class="w-8 h-8 rounded-lg text-xs font-semibold transition-colors ${i === currentPage ? 'bg-stone-800 text-white' : 'border border-stone-300 text-stone-600 hover:bg-stone-100'}">${i}</button>`;
    }
    html += `<button data-page="${currentPage + 1}" ${currentPage === totalPages ? 'disabled' : ''} class="px-3 py-1.5 rounded-lg border text-xs font-semibold transition-colors ${currentPage === totalPages ? 'border-stone-200 text-stone-300 cursor-not-allowed' : 'border-stone-300 text-stone-600 hover:bg-stone-100'}">Next</button>`;
    el.innerHTML = html;
  }

  function setStatus(msg: string, kind: 'info' | 'error' | 'success') {
    const el = document.getElementById('refresh-status')!;
    el.className = 'mb-3 text-sm px-3 py-2 rounded-lg ' + (
      kind === 'error' ? 'bg-red-50 text-red-800 border border-red-200' :
      kind === 'success' ? 'bg-green-50 text-green-800 border border-green-200' :
      'bg-blue-50 text-blue-800 border border-blue-200'
    );
    el.textContent = msg;
  }
  function hideStatus() {
    document.getElementById('refresh-status')!.classList.add('hidden');
  }

  async function triggerRefresh() {
    const btn = document.getElementById('refresh-btn') as HTMLButtonElement;
    const spinner = document.getElementById('refresh-spinner')!;
    const label = document.getElementById('refresh-label')!;

    btn.disabled = true;
    spinner.classList.remove('hidden');
    label.textContent = 'Rebuilding...';
    setStatus('Triggering rebuild — this takes ~30 seconds. Page will reload when the new build is live.', 'info');

    try {
      const resp = await fetch('/api/tools-prospect-stats-rebuild', { method: 'POST' });
      if (!resp.ok) {
        const t = await resp.text();
        throw new Error(`Rebuild endpoint returned ${resp.status}: ${t.slice(0, 200)}`);
      }
      // Poll every 5s for up to 2 min, looking for a newer builtAt on the deployed page
      const originalBuiltAt = (document.getElementById('built-at') as HTMLElement).dataset.iso || '';
      const started = Date.now();
      const timeoutMs = 120_000;

      const poll = async (): Promise<void> => {
        if (Date.now() - started > timeoutMs) {
          setStatus('Rebuild is taking longer than expected. The page will still update once the deploy finishes — reload in a minute.', 'error');
          btn.disabled = false;
          spinner.classList.add('hidden');
          label.textContent = 'Refresh';
          return;
        }
        try {
          const r = await fetch(`/prospect-stats?_=${Date.now()}`, { headers: { 'Accept': 'text/html' } });
          const html = await r.text();
          const match = html.match(/data-iso="([^"]+)"/);
          if (match && match[1] && match[1] !== originalBuiltAt) {
            setStatus('Rebuild complete. Reloading...', 'success');
            setTimeout(() => { location.href = `/prospect-stats?_=${Date.now()}`; }, 800);
            return;
          }
        } catch {}
        setTimeout(poll, 5000);
      };
      setTimeout(poll, 10_000);
    } catch (err: any) {
      setStatus(`Refresh failed: ${err.message}`, 'error');
      btn.disabled = false;
      spinner.classList.add('hidden');
      label.textContent = 'Refresh';
    }
  }

  document.getElementById('search')!.addEventListener('input', applyFilters);
  document.getElementById('filter-status')!.addEventListener('change', applyFilters);
  document.getElementById('refresh-btn')!.addEventListener('click', triggerRefresh);

  document.querySelectorAll('[data-sort]').forEach(th => {
    th.addEventListener('click', () => {
      const field = (th as HTMLElement).dataset.sort!;
      if (sortField === field) {
        sortDir = sortDir === 'asc' ? 'desc' : 'asc';
      } else {
        sortField = field;
        sortDir = field === 'sentAt' ? 'desc' : 'asc';
      }
      applyFilters();
    });
  });

  document.getElementById('pagination')!.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('button') as HTMLButtonElement | null;
    if (!btn || btn.disabled) return;
    const page = parseInt(btn.dataset.page!);
    const totalPages = Math.ceil(filtered.length / PER_PAGE);
    if (page >= 1 && page <= totalPages) {
      currentPage = page;
      render();
      document.getElementById('table-wrap')!.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  });

  // Initial render
  applyFilters();
</script>
</PortalLayout>
