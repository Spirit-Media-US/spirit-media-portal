---
import "../styles/globals.css";
const error = Astro.url.searchParams.get("error");
const next = Astro.url.searchParams.get("next") || "/clients";
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Client Login | Spirit Media Publishing</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="wrap">
      <div class="card">
        <img src="https://cdn.sanity.io/images/pmowd8uo/production/dc16e3c604bd5d52de7647af46836ff418c22898-6575x656.png?w=440&h=88&fit=max&auto=format" alt="Spirit Media Publishing" class="logo" />

        <form method="POST" action="/api/client-auth">
          <input type="hidden" name="next" value={next} />
          <label for="pin">Enter your PIN</label>
          <input id="pin" name="pin" type="password" inputmode="numeric" maxlength="6" placeholder="••••••" autocomplete="off" autofocus />
          {error && <p class="error">Incorrect PIN — try again.</p>}
          <button type="submit">Continue</button>
        </form>

        <p class="foot">Need help? <a href="mailto:hello@spiritmediapublishing.com">hello@spiritmediapublishing.com</a></p>
      </div>
    </div>
  </body>
</html>

<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: "IBM Plex Sans", system-ui, sans-serif; background: #faf8f5; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
  .wrap { width: 100%; display: flex; align-items: center; justify-content: center; padding: 2rem; }
  .card { background: #fff; border: 1px solid #e2e8f0; border-radius: 0.75rem; padding: 3rem 2.5rem; width: 100%; max-width: 380px; box-shadow: 0 4px 24px rgba(0,0,0,0.07); text-align: center; }
  .logo { max-width: 220px; height: auto; margin: 0 auto 2rem; display: block; }
  label { display: block; font-size: 0.875rem; font-weight: 600; color: #374151; margin-bottom: 0.5rem; text-align: left; }
  input[type="password"] { width: 100%; padding: 0.75rem 1rem; font-size: 1.25rem; letter-spacing: 0.3em; text-align: center; border: 1.5px solid #d1d5db; border-radius: 0.375rem; background: #f9fafb; outline: none; margin-bottom: 1rem; transition: border-color 150ms; }
  input[type="password"]:focus { border-color: #b91c1c; background: #fff; }
  .error { color: #b91c1c; font-size: 0.8rem; margin-bottom: 0.75rem; }
  button { width: 100%; padding: 0.875rem; background: #b91c1c; color: #fff; font-family: inherit; font-size: 0.875rem; font-weight: 700; border: none; border-radius: 0.375rem; cursor: pointer; transition: background 150ms; }
  button:hover { background: #991b1b; }
  .foot { margin-top: 1.5rem; font-size: 0.75rem; color: #9ca3af; }
  .foot a { color: #9ca3af; text-decoration: underline; }
</style>
