---
import PortalLayout from "../layouts/PortalLayout.astro";

interface Site {
	name: string;
	repo: string;
	pagesProject: string; // Cloudflare Pages project name
	sanity: string;
	liveUrl: string; // empty string = not yet live → red dot
}

const sites: Site[] = [
	{
		name: "10 Billion Travelers",
		repo: "10-billion-travelers",
		pagesProject: "10-billion-travelers",
		sanity: "10billiontravelers.sanity.studio",
		liveUrl: "10btravelers.com",
	},
	{
		name: "Arts By Justin",
		repo: "artsbyjustin",
		pagesProject: "artsbyjustin",
		sanity: "artsbyjustin.sanity.studio",
		liveUrl: "artsbyjustin.com",
	},
	{
		name: "Clowning from the Heart",
		repo: "clowning-from-the-heart",
		pagesProject: "clowning-from-the-heart",
		sanity: "clowningfromtheheart.sanity.studio",
		liveUrl: "clowningfromtheheart.com",
	},
	{
		name: "Father's Heart Bible",
		repo: "FHB",
		pagesProject: "fathersheartbible",
		sanity: "fathersheartbible.sanity.studio",
		liveUrl: "fathersheartbible.com",
	},
	{
		name: "Global Hope India",
		repo: "global-hope-india",
		pagesProject: "global-hope-india",
		sanity: "",
		liveUrl: "globalhopeindia.org",
	},
	{
		name: "Kevin White",
		repo: "kevin-white-us",
		pagesProject: "kevin-white-us",
		sanity: "",
		liveUrl: "",
	},
	{
		name: "Johnny Watts Agency",
		repo: "john-watts-agency",
		pagesProject: "john-watts-agency",
		sanity: "johnnywattsagency.sanity.studio",
		liveUrl: "johnnywattsagency.com",
	},
	{
		name: "LionCrest Media",
		repo: "lioncrest-media",
		pagesProject: "lioncrest-media",
		sanity: "",
		liveUrl: "",
	},
	{
		name: "Scripture Alive",
		repo: "scripture-alive",
		pagesProject: "scripture-alive",
		sanity: "",
		liveUrl: "scripturealive.com",
	},
	{
		name: "SM Gives",
		repo: "sm-gives",
		pagesProject: "sm-gives",
		sanity: "",
		liveUrl: "smgives.org",
	},
	{
		name: "Spirit Media Publishing",
		repo: "spirit-media-publishing",
		pagesProject: "spirit-media-publishing",
		sanity: "spiritmediapublishing.sanity.studio",
		liveUrl: "spiritmediapublishing.com",
	},
	{
		name: "The Kohler Group",
		repo: "the-kohler-group",
		pagesProject: "the-kohler-group",
		sanity: "thekohlergroup.sanity.studio",
		liveUrl: "thekohlergroup.net",
	},
	{
		name: "Work On Yourself",
		repo: "WOY",
		pagesProject: "workonyourself",
		sanity: "workonyourself.sanity.studio",
		liveUrl: "workonyourself.com",
	},
];
---

<PortalLayout title="Dashboard" mainBg="#fef2f2">
  <div class="page-header">
    <h1>Dashboard</h1>
    <p>Site inventory and management links</p>
  </div>

  <div id="sites-grid" class="sites-grid">
    {sites.map((site) => (
      <div class="site-card">
        <div class="site-card-header">
          <h2>{site.name}</h2>
          <span class="slug">{site.pagesProject}</span>
        </div>
        <div class="btn-grid">
          <a href={site.liveUrl ? `https://${site.liveUrl}` : `https://${site.pagesProject}.pages.dev`} target="_blank" rel="noopener noreferrer" class="btn">
            <span class={`status-lights${!site.liveUrl ? ' down' : ''}`} data-url={site.liveUrl || null}>
              <span class="light green"></span><span class="light red"></span>
            </span> Live
          </a>
          <a href={`https://dev.${site.pagesProject}.pages.dev`} target="_blank" rel="noopener noreferrer" class="btn" title="Dev branch preview">👁 Dev</a>
          <a href={`https://${site.pagesProject}.pages.dev`} target="_blank" rel="noopener noreferrer" class="btn" title="Main branch (production)">🚀 Main</a>
          <a href={site.sanity ? `https://${site.sanity}` : site.liveUrl ? `https://${site.liveUrl}/studio/` : `https://${site.pagesProject}.pages.dev/studio/`} target="_blank" rel="noopener noreferrer" class="btn">✏️ Sanity</a>
          <a href={`https://github.com/Spirit-Media-US/${site.repo}`} target="_blank" rel="noopener noreferrer" class="btn">🗂 GitHub</a>
          <a href={`https://dash.cloudflare.com/?to=/:account/pages/view/${site.pagesProject}`} target="_blank" rel="noopener noreferrer" class="btn" title="Cloudflare Pages dashboard">📋 Pages</a>
          <a href={site.liveUrl ? `https://search.google.com/search-console?resource_id=sc-domain:${site.liveUrl}` : '#'} target="_blank" rel="noopener noreferrer" class="btn">📊 Search</a>
          {site.liveUrl
            ? <a href={`https://${site.liveUrl}/studio/`} target="_blank" rel="noopener noreferrer" class="btn" title="Client link — Sanity Studio">🎨 Studio</a>
            : <a href={`https://${site.pagesProject}.pages.dev/studio/`} target="_blank" rel="noopener noreferrer" class="btn" title="Sanity Studio">🎨 Studio</a>}
        </div>
      </div>
    ))}
  </div>

  <!-- Pipeline projects from registry (new builds not yet in the list above) -->
  <div id="pipeline-section" class="hidden">
    <h2 class="pipeline-heading">In Pipeline</h2>
    <div id="pipeline-grid" class="sites-grid"></div>
  </div>
</PortalLayout>

<style>
  .page-header { margin-bottom: 2rem; }
  .page-header h1 {
    font-family: "Playfair Display", Georgia, serif;
    font-size: 2rem; font-weight: 700;
    color: #1a1714; margin-bottom: 0.25rem;
  }
  .page-header p { color: #7a6e63; font-size: 0.9375rem; }

  .pipeline-heading {
    font-family: "Playfair Display", Georgia, serif;
    font-size: 1.25rem; font-weight: 700;
    color: #1a1714; margin: 2rem 0 1rem;
  }

  .sites-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  .site-card {
    background: #ffffff;
    border: 1px solid #ddd7cf;
    border-radius: 0.5rem;
    padding: 1.5rem;
    box-shadow: 0 1px 4px rgba(26,23,20,0.06);
  }

  .site-card-header {
    margin-bottom: 1rem;
    padding-bottom: 0.875rem;
    border-bottom: 1px solid #ede7df;
  }

  .site-card-header h2 {
    font-family: "Playfair Display", Georgia, serif;
    font-size: 0.9375rem; font-weight: 700;
    color: #1a1714; margin: 0;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .site-card-header .slug {
    display: block;
    font-size: 0.6875rem;
    color: #a8a29e;
    font-family: monospace;
    margin-top: 0.2rem;
  }

  .status-lights {
    display: inline-flex; gap: 0.2rem; align-items: center;
  }
  .light {
    width: 0.45rem; height: 0.45rem;
    border-radius: 50%;
    background: #e7e5e4;
  }
  .light.green { background: #d6d3d1; }
  .light.red   { background: #d6d3d1; }
  .status-lights.up   .light.green { background: #22c55e; }
  .status-lights.down .light.red   { background: #ef4444; }

  .btn-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 0.375rem;
  }

  .btn {
    display: flex; align-items: center; justify-content: center;
    gap: 0.375rem;
    padding: 0.4rem 0.5rem;
    min-height: 2.25rem;
    border-radius: 0.375rem;
    text-decoration: none;
    font-size: 0.8125rem; font-weight: 600;
    transition: opacity 150ms, box-shadow 150ms;
    text-align: center;
    background: #f5f1ec; color: #2e2a26;
    border: 1px solid #ddd7cf;
    white-space: nowrap;
  }
  .btn:hover { background: #fff; border-color: #c0392b; }
</style>

<script>
  // Ping live sites — skip if no data-url
  document.querySelectorAll('.status-lights[data-url]').forEach((el) => {
    const url = el.getAttribute('data-url');
    if (!url) return;
    fetch(`https://${url}`, { mode: 'no-cors', cache: 'no-store' })
      .then(() => el.classList.add('up'))
      .catch(() => el.classList.add('down'));
  });

  // Load pipeline projects from registry (new clients not yet in hardcoded list)
  const KNOWN_SLUGS = new Set([
    '10-billion-travelers', 'artsbyjustin', 'clowning-from-the-heart', 'FHB',
    'global-hope-india', 'grace-community-church', 'john-watts-agency', 'kevin-white-us', 'lioncrest-media', 'sm-gives', 'scripture-alive', 'spirit-media-publishing', 'the-kohler-group', 'WOY',
  ]);

  const STATUS_LABEL: Record<string, string> = {
    proposal_pending: 'Proposal Running',
    proposal_failed:  'Proposal Failed',
    proposal_ready:   'Proposal Ready',
    built:            'In Development',
    build_failed:     'Build Failed',
    qa_failed:        'QA — Fixes Needed',
    qa_passed:        'QA Passed',
    launched:         'Live',
  };

  // Projects with infrastructure (built+) join the main grid.
  // Only pre-build proposals stay in the "In Pipeline" section.
  // Show on main grid as soon as bootstrap starts (proposal_pending = registry entry just created)
  const BUILD_STATUSES = new Set(['proposal_pending', 'built', 'build_failed', 'qa_failed', 'qa_passed', 'launched']);

  function makeCard(p: any) {
    const isLive    = p.status === 'launched' && p.live_url;
    const pagesProject = p.slug;
    const liveHref  = isLive ? `https://${p.live_url}` : `https://${pagesProject}.pages.dev`;
    const liveClass = isLive ? '' : ' down';
    const liveDataUrl = isLive ? p.live_url : null;
    return `
      <div class="site-card">
        <div class="site-card-header">
          <h2 title="${p.title}">${p.title}</h2>
          <span class="slug">${pagesProject}</span>
        </div>
        <div class="btn-grid">
          <a href="${liveHref}" target="_blank" rel="noopener noreferrer" class="btn">
            <span class="status-lights${liveClass}"${liveDataUrl ? ` data-url="${liveDataUrl}"` : ''}>
              <span class="light green"></span><span class="light red"></span>
            </span> Live
          </a>
          <a href="https://dev.${pagesProject}.pages.dev" target="_blank" rel="noopener noreferrer" class="btn" title="Dev branch preview">👁 Dev</a>
          <a href="https://${pagesProject}.pages.dev" target="_blank" rel="noopener noreferrer" class="btn" title="Main branch (production)">🚀 Main</a>
          ${p.sanity_studio
            ? `<a href="${p.sanity_studio}" target="_blank" rel="noopener noreferrer" class="btn">✏️ Sanity</a>`
            : `<span class="btn" style="opacity:.4;cursor:default">✏️ Sanity</span>`}
          ${p.github
            ? `<a href="${p.github}" target="_blank" rel="noopener noreferrer" class="btn">🗂 GitHub</a>`
            : `<span class="btn" style="opacity:.4;cursor:default">🗂 GitHub</span>`}
          <a href="https://dash.cloudflare.com/?to=/:account/pages/view/${pagesProject}" target="_blank" rel="noopener noreferrer" class="btn" title="Cloudflare Pages dashboard">📋 Pages</a>
          ${isLive && p.live_url
            ? `<a href="https://search.google.com/search-console?resource_id=sc-domain:${p.live_url}" target="_blank" rel="noopener noreferrer" class="btn">📊 Search</a>`
            : p.proposal_url
              ? `<a href="${p.proposal_url}" target="_blank" rel="noopener noreferrer" class="btn">📄 Proposal</a>`
              : `<span class="btn" style="opacity:.4;cursor:default">📄 Proposal</span>`}
          ${isLive && p.live_url
            ? `<a href="https://${p.live_url}/studio/" target="_blank" rel="noopener noreferrer" class="btn" title="Client link — Sanity Studio">🎨 Studio</a>`
            : `<a href="https://${pagesProject}.pages.dev/studio/" target="_blank" rel="noopener noreferrer" class="btn" title="Sanity Studio">🎨 Studio</a>`}
        </div>
      </div>`;
  }

  async function loadPipeline() {
    try {
      const resp     = await fetch('/api/tools-projects');
      const projects = await resp.json();
      const unknown  = (projects as any[]).filter(p => p.title && p.slug && !KNOWN_SLUGS.has(p.slug));

      // Built+ → inject into main grid in alpha order
      const active = unknown
        .filter(p => BUILD_STATUSES.has(p.status))
        .sort((a, b) => a.title.localeCompare(b.title));

      if (active.length) {
        const grid = document.getElementById('sites-grid')!;
        // Insert each card in alpha order among existing cards
        active.forEach(p => {
          const html = makeCard(p);
          const tmp  = document.createElement('div');
          tmp.innerHTML = html.trim();
          const card = tmp.firstElementChild as HTMLElement;
          const title = p.title.toLowerCase();
          const existing = Array.from(grid.children) as HTMLElement[];
          const after = existing.find(el => {
            const h2 = el.querySelector('h2');
            return h2 && h2.textContent!.trim().toLowerCase() > title;
          });
          after ? grid.insertBefore(card, after) : grid.appendChild(card);
        });
        // Ping any newly added live sites
        document.querySelectorAll('#sites-grid .status-lights[data-url]').forEach(el => {
          const url = el.getAttribute('data-url');
          if (!url) return;
          fetch(`https://${url}`, { mode: 'no-cors', cache: 'no-store' })
            .then(() => el.classList.add('up'))
            .catch(() => el.classList.add('down'));
        });
      }

      // Proposal-stage only → "In Pipeline" section
      const proposals = unknown.filter(p => !BUILD_STATUSES.has(p.status));
      if (proposals.length) {
        document.getElementById('pipeline-section')!.classList.remove('hidden');
        document.getElementById('pipeline-grid')!.innerHTML = proposals
          .sort((a, b) => a.title.localeCompare(b.title))
          .map(makeCard).join('');
      }
    } catch { /* registry unavailable */ }
  }

  loadPipeline();


</script>
