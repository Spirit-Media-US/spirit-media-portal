---
import PortalLayout from '../layouts/PortalLayout.astro';

interface Site {
  name: string;
  slug: string;
  netlify: string;
  sanity: string;
  liveUrl: string;
}

const sites: Site[] = [
  { name: 'Spirit Media Publishing', slug: 'smp', netlify: 'spiritmediapublishing.netlify.app', sanity: 'spiritmediapublishing.sanity.studio', liveUrl: 'spiritmediapublishing.com' },
  { name: "Father's Heart Bible", slug: 'fhb', netlify: 'fathersheartbible.netlify.app', sanity: 'fathersheartbible.sanity.studio', liveUrl: 'fathersheartbible.org' },
  { name: 'Work On Yourself', slug: 'woy', netlify: 'workonyourself.netlify.app', sanity: 'workonyourself.sanity.studio', liveUrl: 'workonyourself.com' },
  { name: 'Arts By Justin', slug: 'artsbyjustin', netlify: 'artsbyjustin.netlify.app', sanity: 'artsbyjustin.sanity.studio', liveUrl: 'artsbyjustin.com' },
  { name: 'The Kohler Group', slug: 'kohler', netlify: 'thekohlergroup.netlify.app', sanity: 'thekohlergroup.sanity.studio', liveUrl: 'thekohlergroup.net' },
];
---

<PortalLayout title="Dashboard">
  <div class="page-header">
    <h1>Dashboard</h1>
    <p>Site inventory and management links</p>
  </div>

  <div class="sites-grid">
    {sites.map((site) => (
      <div class="site-card">
        <div class="site-card-header">
          <h2>{site.name}</h2>
          <code class="site-slug">{site.slug}</code>
        </div>
        <div class="site-links">
          <a href={`https://${site.liveUrl}`} target="_blank" rel="noopener noreferrer" class="site-link">
            <span>Live Website</span>
            <span class="link-url">{site.liveUrl} →</span>
          </a>
          <a href={`https://app.netlify.com/projects/${site.netlify.split('.')[0]}`} target="_blank" rel="noopener noreferrer" class="site-link">
            <span>Netlify Admin</span>
            <span class="link-action">Manage →</span>
          </a>
          <a href={`https://${site.sanity}`} target="_blank" rel="noopener noreferrer" class="site-link">
            <span>Sanity Studio</span>
            <span class="link-action">Edit Content →</span>
          </a>
        </div>
      </div>
    ))}
  </div>
</PortalLayout>

<style>
  .page-header { margin-bottom: 2rem; }
  .page-header h1 {
    font-family: "Playfair Display", Georgia, serif;
    font-size: 2rem; font-weight: 700;
    color: #1a1714; margin-bottom: 0.25rem;
  }
  .page-header p { color: #7a6e63; font-size: 0.9375rem; }

  .sites-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
    gap: 1.25rem;
  }

  .site-card {
    background: #ffffff;
    border: 1px solid #ddd7cf;
    border-radius: 0.5rem;
    padding: 1.5rem;
    box-shadow: 0 1px 4px rgba(26,23,20,0.06);
  }

  .site-card-header {
    display: flex; align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
    padding-bottom: 0.875rem;
    border-bottom: 1px solid #ede7df;
  }

  .site-card-header h2 {
    font-family: "Playfair Display", Georgia, serif;
    font-size: 1.0625rem; font-weight: 700;
    color: #1a1714; margin: 0;
  }

  .site-slug {
    font-size: 0.7rem; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    background: #f5f1ec; color: #7a6e63;
    padding: 0.2rem 0.5rem; border-radius: 0.25rem;
    font-family: "Courier New", monospace;
  }

  .site-links { display: flex; flex-direction: column; gap: 0.375rem; }

  .site-link {
    display: flex; align-items: center;
    justify-content: space-between;
    padding: 0.625rem 0.875rem;
    background: #faf8f5;
    border: 1px solid #ede7df;
    border-radius: 0.375rem;
    text-decoration: none;
    transition: border-color 150ms, background 150ms;
    font-size: 0.875rem;
  }

  .site-link:hover {
    background: #fff;
    border-color: #c0392b;
  }

  .site-link span:first-child {
    font-weight: 600; color: #2e2a26;
  }

  .link-url { color: #7a6e63; font-size: 0.8125rem; }
  .link-action { color: #c0392b; font-size: 0.8125rem; font-weight: 600; }
</style>
