---
import PortalLayout from '../layouts/PortalLayout.astro';
---

<PortalLayout title="Tools">
  <div class="max-w-3xl">
    <h1 class="text-4xl font-bold mb-2">Tools</h1>
    <p class="text-stone-600 mb-10">Spirit Media build pipeline — run steps in sequence for each client project.</p>

    <!-- ── Step 1: Website Migration Proposal ──────────────── -->
    <div class="bg-white rounded-2xl border border-stone-200 p-8 mb-6 shadow-sm">
      <div class="flex items-center gap-3 mb-1">
        <span class="w-7 h-7 rounded-full bg-stone-800 text-white text-xs font-bold flex items-center justify-center shrink-0">1</span>
        <h2 class="text-2xl font-bold">Website Migration Proposal</h2>
      </div>
      <p class="text-stone-500 text-sm mb-6 ml-10">Enter the client's current site URL. Generates the full proposal and complexity report with bottom / mid / top pricing. Creates a project record for Steps 2 and 3.</p>

      <form id="proposal-form" class="space-y-4">
        <input type="url" id="site-url" required placeholder="https://clientsite.com"
          class="w-full border border-stone-300 rounded-lg px-4 py-3 text-stone-800 placeholder-stone-400 focus:outline-none focus:ring-2 focus:ring-stone-400 text-base" />
        <button type="submit" id="proposal-btn"
          class="w-full bg-stone-800 hover:bg-stone-700 text-white font-semibold py-3 px-6 rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
          Generate Proposal
        </button>
      </form>

      <div id="proposal-status" class="hidden mt-5">
        <div id="proposal-spinner" class="hidden flex items-center gap-3 text-stone-600 text-sm">
          <svg class="animate-spin h-4 w-4 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path>
          </svg>
          <span>Auditing site and building proposal — 2–4 minutes…</span>
        </div>
        <div id="proposal-result" class="hidden p-5 bg-green-50 border border-green-200 rounded-xl space-y-2">
          <p class="text-sm font-bold text-green-800">Proposal ready! Project added to pipeline.</p>
          <a id="proposal-link" href="#" target="_blank" rel="noopener noreferrer" class="block text-green-700 underline font-medium text-sm">Open Proposal →</a>
          <a id="report-link" href="#" target="_blank" rel="noopener noreferrer" class="block text-green-700 underline text-sm hidden">Open Complexity Report →</a>
          <p class="text-xs text-stone-500 pt-1">When the sale closes, use Step 2 below to initiate the build.</p>
        </div>
        <div id="proposal-error" class="hidden p-4 bg-red-50 border border-red-200 rounded-xl">
          <p class="text-sm font-bold text-red-800 mb-1">Error</p>
          <p id="proposal-error-text" class="text-sm text-red-700 font-mono whitespace-pre-wrap"></p>
        </div>
      </div>
    </div>

    <!-- ── Step 2: Initiate Build ───────────────────────────── -->
    <div class="bg-white rounded-2xl border border-stone-200 p-8 mb-6 shadow-sm">
      <div class="flex items-center gap-3 mb-1">
        <span class="w-7 h-7 rounded-full bg-stone-800 text-white text-xs font-bold flex items-center justify-center shrink-0">2</span>
        <h2 class="text-2xl font-bold">Initiate Build</h2>
      </div>
      <p class="text-stone-500 text-sm mb-6 ml-10">Sale closed? Enter the project details below. Creates the GitHub repo, Sanity project, and Netlify site — fully automated.</p>

      <div class="space-y-4">
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label for="build-title" class="block text-sm font-semibold text-stone-700 mb-1">Site Name</label>
            <input id="build-title" type="text" placeholder="Global Hope India"
              class="w-full border border-stone-300 rounded-lg px-4 py-2.5 text-stone-800 focus:outline-none focus:ring-2 focus:ring-stone-400" />
          </div>
          <div>
            <label for="build-slug" class="block text-sm font-semibold text-stone-700 mb-1">Slug</label>
            <input id="build-slug" type="text" placeholder="global-hope-india"
              class="w-full border border-stone-300 rounded-lg px-4 py-2.5 text-stone-800 font-mono focus:outline-none focus:ring-2 focus:ring-stone-400" />
          </div>
        </div>
        <div>
          <label for="build-client-url" class="block text-sm font-semibold text-stone-700 mb-1">Client's Existing URL</label>
          <input id="build-client-url" type="url" placeholder="https://globalhopeindia.org"
            class="w-full border border-stone-300 rounded-lg px-4 py-2.5 text-stone-800 focus:outline-none focus:ring-2 focus:ring-stone-400" />
        </div>
        <button id="bootstrap-btn"
          class="w-full bg-stone-800 hover:bg-stone-700 text-white font-semibold py-3 px-6 rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
          Initiate Build — Phase 1
        </button>
      </div>

      <div id="bootstrap-status" class="hidden mt-5">
        <div id="bootstrap-spinner" class="hidden flex items-center gap-3 text-stone-600 text-sm">
          <svg class="animate-spin h-4 w-4 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path>
          </svg>
          <span>Creating infrastructure — GitHub, Sanity, Netlify… (~2 min)</span>
        </div>
        <div id="bootstrap-result" class="hidden p-5 bg-green-50 border border-green-200 rounded-xl space-y-3">
          <p class="text-sm font-bold text-green-800">Phase 1 complete! Project updated in pipeline.</p>
          <div id="bootstrap-links" class="space-y-1.5"></div>
          <p class="text-xs text-stone-500">Next: SSH into Bethel, <code class="bg-stone-100 px-1 rounded">cd ~/Sites/<span id="bootstrap-slug-echo"></span></code>, run <code class="bg-stone-100 px-1 rounded">claude</code>, work through Phases 2–4.</p>
        </div>
        <div id="bootstrap-error" class="hidden p-4 bg-red-50 border border-red-200 rounded-xl">
          <p class="text-sm font-bold text-red-800 mb-1">Error</p>
          <p id="bootstrap-error-text" class="text-sm text-red-700 font-mono whitespace-pre-wrap"></p>
        </div>
      </div>
    </div>

    <!-- ── Step 3: Pre-Launch QA ────────────────────────────── -->
    <div class="bg-white rounded-2xl border border-stone-200 p-8 mb-10 shadow-sm">
      <div class="flex items-center gap-3 mb-1">
        <span class="w-7 h-7 rounded-full bg-stone-800 text-white text-xs font-bold flex items-center justify-center shrink-0">3</span>
        <h2 class="text-2xl font-bold">Pre-Launch QA</h2>
      </div>
      <p class="text-stone-500 text-sm mb-6 ml-10">Run after the Audit Gate. Select a project that has completed Phase 1. Scans for hardcoded colors, missing alt text, missing SEO meta, leftover WordPress URLs, broken links, and TODO comments. Returns pass/fail for human review before delivery.</p>

      <div class="space-y-4">
        <div>
          <label for="qa-project" class="block text-sm font-semibold text-stone-700 mb-1">Project</label>
          <select id="qa-project"
            class="w-full border border-stone-300 rounded-lg px-4 py-2.5 text-stone-800 focus:outline-none focus:ring-2 focus:ring-stone-400 bg-white">
            <option value="">Loading pipeline…</option>
          </select>
        </div>
        <button id="qa-btn"
          class="w-full bg-stone-800 hover:bg-stone-700 text-white font-semibold py-3 px-6 rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
          Run Pre-Launch QA
        </button>
      </div>

      <div id="qa-status" class="hidden mt-5">
        <div id="qa-spinner" class="hidden flex items-center gap-3 text-stone-600 text-sm">
          <svg class="animate-spin h-4 w-4 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path>
          </svg>
          <span>Running scans…</span>
        </div>
        <div id="qa-result" class="hidden">
          <div id="qa-summary" class="mb-4 p-4 rounded-lg text-sm font-semibold"></div>
          <div id="qa-scans" class="space-y-3"></div>
        </div>
        <div id="qa-error" class="hidden p-4 bg-red-50 border border-red-200 rounded-xl">
          <p class="text-sm font-bold text-red-800 mb-1">Error</p>
          <p id="qa-error-text" class="text-sm text-red-700 font-mono whitespace-pre-wrap"></p>
        </div>
      </div>
    </div>

    <!-- ── Document Generator ─────────────────────────────────── -->
    <div class="bg-white rounded-2xl border border-stone-200 p-8 mb-10 shadow-sm">
      <h2 class="text-2xl font-bold mb-1">Document Generator</h2>
      <p class="text-stone-500 text-sm mb-6">Generate a document from a template. Paste a Google Drive link — Google Doc, Word, or PDF all work.</p>
      <form id="generate-form" class="space-y-6">
        <div>
          <label for="template-select" class="block text-sm font-semibold text-stone-700 mb-2">Template</label>
          <select id="template-select" name="template_id" required
            class="w-full border border-stone-300 rounded-lg px-4 py-3 text-stone-800 focus:outline-none focus:ring-2 focus:ring-stone-400 bg-white">
            <option value="">Loading templates…</option>
          </select>
        </div>
        <div>
          <label for="file-url" class="block text-sm font-semibold text-stone-700 mb-2">Manuscript Link</label>
          <input type="url" id="file-url" name="file_url" required placeholder="https://docs.google.com/document/d/…"
            class="w-full border border-stone-300 rounded-lg px-4 py-3 text-stone-800 placeholder-stone-400 focus:outline-none focus:ring-2 focus:ring-stone-400" />
          <p class="text-xs text-stone-500 mt-1">Supports Google Docs, Word (.docx), and PDF files from Google Drive.</p>
        </div>
        <button type="submit" id="submit-btn"
          class="w-full bg-stone-800 hover:bg-stone-700 text-white font-semibold py-3 px-6 rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
          Generate
        </button>
      </form>
      <div id="status" class="hidden mt-6">
        <div id="status-spinner" class="hidden flex items-center gap-3 text-stone-600">
          <svg class="animate-spin h-5 w-5 text-stone-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path>
          </svg>
          <span id="status-text">Reading manuscript…</span>
        </div>
        <div id="status-result" class="hidden p-4 bg-green-50 border border-green-200 rounded-lg">
          <p class="text-sm font-semibold text-green-800 mb-2">Done!</p>
          <a id="result-link" href="#" target="_blank" rel="noopener noreferrer" class="text-green-700 underline font-medium break-all"></a>
        </div>
        <div id="status-error" class="hidden p-4 bg-red-50 border border-red-200 rounded-lg">
          <p class="text-sm font-semibold text-red-800 mb-1">Error</p>
          <p id="error-text" class="text-sm text-red-700"></p>
        </div>
      </div>
    </div>

    <!-- ── Blog Post Publisher ────────────────────────────────── -->
    <div class="bg-white rounded-2xl border border-stone-200 p-8 mb-10 shadow-sm">
      <h2 class="text-2xl font-bold mb-1">Publish Blog Post</h2>
      <p class="text-stone-500 text-sm mb-6">Paste your content — Claude extracts all fields and publishes directly to Sanity.</p>
      <form id="blog-form" class="space-y-5">
        <div>
          <label for="blog-content" class="block text-sm font-semibold text-stone-700 mb-2">Blog Content</label>
          <textarea id="blog-content" name="content" required rows="14" placeholder="Paste everything here — title, body, SEO title, meta description, whatever you have. Claude will sort it out."
            class="w-full border border-stone-300 rounded-lg px-4 py-3 text-stone-800 placeholder-stone-400 focus:outline-none focus:ring-2 focus:ring-stone-400 font-mono text-sm resize-y"></textarea>
        </div>
        <div>
          <label for="hero-image-url" class="block text-sm font-semibold text-stone-700 mb-2">Feature Image URL <span class="text-stone-400 font-normal">(optional)</span></label>
          <input type="url" id="hero-image-url" name="hero_image_url" placeholder="https://cdn.sanity.io/images/pmowd8uo/production/…"
            class="w-full border border-stone-300 rounded-lg px-4 py-3 text-stone-800 placeholder-stone-400 focus:outline-none focus:ring-2 focus:ring-stone-400" />
          <p class="text-xs text-stone-400 mt-1">Upload in Sanity Studio → copy the CDN URL → paste here.</p>
        </div>
        <button type="submit" id="blog-submit-btn"
          class="w-full bg-stone-800 hover:bg-stone-700 text-white font-semibold py-3 px-6 rounded-lg transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
          Publish to Sanity
        </button>
      </form>
      <div id="blog-status" class="hidden mt-6">
        <div id="blog-spinner" class="hidden flex items-center gap-3 text-stone-600">
          <svg class="animate-spin h-5 w-5 text-stone-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path>
          </svg>
          <span id="blog-status-text">Parsing content…</span>
        </div>
        <div id="blog-result" class="hidden p-5 bg-green-50 border border-green-200 rounded-lg space-y-2">
          <p class="text-sm font-semibold text-green-800">Published!</p>
          <a id="blog-live-url" href="#" target="_blank" rel="noopener noreferrer" class="block text-sm text-green-700 underline font-medium break-all"></a>
          <a id="blog-studio-url" href="#" target="_blank" rel="noopener noreferrer" class="block text-xs text-green-600 underline break-all"></a>
        </div>
        <div id="blog-error" class="hidden p-4 bg-red-50 border border-red-200 rounded-lg">
          <p class="text-sm font-semibold text-red-800 mb-1">Error</p>
          <p id="blog-error-text" class="text-sm text-red-700"></p>
        </div>
      </div>
    </div>

    <!-- ── Recent Documents ───────────────────────────────────── -->
    <div>
      <h2 class="text-2xl font-bold mb-4">Recent Documents</h2>
      <div id="history-list" class="space-y-2">
        <p class="text-stone-500 text-sm">Loading…</p>
      </div>
    </div>
  </div>
</PortalLayout>

<script>
if (!(window as any).__portalInitialized) {
  (window as any).__portalInitialized = true;

  // ── Project registry helpers ─────────────────────────────────
  let allProjects: any[] = [];

  async function loadProjects() {
    try {
      const resp = await fetch('/api/tools-projects');
      allProjects = await resp.json();
    } catch { allProjects = []; }

    populateQADropdown();
  }

  function statusLabel(s: string) {
    const map: Record<string, string> = {
      proposal_pending: 'proposal running…',
      proposal_failed:  'proposal failed',
      proposal_ready:   'proposal ready',
      building:         'building…',
      build_failed:     'build failed',
      built:            'built — dev in progress',
      qa_failed:        'QA failed',
      qa_passed:        'QA passed',
      launched:         'launched',
    };
    return map[s] ?? s;
  }

function populateQADropdown() {
    const sel = document.getElementById('qa-project') as HTMLSelectElement;
    const eligible = allProjects.filter(p => ['built', 'qa_failed', 'qa_passed'].includes(p.status));
    if (!eligible.length) {
      sel.innerHTML = '<option value="">No projects with completed builds yet</option>';
      return;
    }
    sel.innerHTML = '<option value="">Select a project…</option>' +
      eligible.map(p => `<option value="${p.id}">${p.title} (${statusLabel(p.status)})</option>`).join('');
  }

  // ── 1. Website Migration Proposal ──────────────────────────
  document.getElementById('proposal-form')!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const url = (document.getElementById('site-url') as HTMLInputElement).value.trim();
    const btn = document.getElementById('proposal-btn') as HTMLButtonElement;
    btn.disabled = true; btn.textContent = 'Generating…';
    document.getElementById('proposal-status')!.classList.remove('hidden');
    document.getElementById('proposal-spinner')!.classList.remove('hidden');
    document.getElementById('proposal-result')!.classList.add('hidden');
    document.getElementById('proposal-error')!.classList.add('hidden');

    try {
      // Start the job (returns immediately with project_id)
      const resp = await fetch('/api/tools-proposal', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ url }),
      });
      const start = await resp.json();
      if (start.error) throw new Error(start.error);

      const jobId = start.job_id;

      // Poll every 4s until done or failed
      const poll = async (): Promise<void> => {
        await new Promise(r => setTimeout(r, 4000));
        const pr = await fetch(`/api/tools-proposal-status?job_id=${jobId}`);
        const job = await pr.json();
        if (job.status === 'pending') return poll();
        document.getElementById('proposal-spinner')!.classList.add('hidden');
        if (job.status === 'failed') {
          document.getElementById('proposal-error')!.classList.remove('hidden');
          document.getElementById('proposal-error-text')!.textContent = job.log || 'Proposal generation failed.';
        } else {
          document.getElementById('proposal-result')!.classList.remove('hidden');
          (document.getElementById('proposal-link') as HTMLAnchorElement).href = job.proposal_url;
          if (job.report_url) {
            const r = document.getElementById('report-link') as HTMLAnchorElement;
            r.href = job.report_url; r.classList.remove('hidden');
          }
        }
        btn.disabled = false; btn.textContent = 'Generate Proposal';
      };
      poll();
    } catch (err: any) {
      document.getElementById('proposal-spinner')!.classList.add('hidden');
      document.getElementById('proposal-error')!.classList.remove('hidden');
      document.getElementById('proposal-error-text')!.textContent = err.message;
      btn.disabled = false; btn.textContent = 'Generate Proposal';
    }
  });

  // ── 2. Initiate Build ───────────────────────────────────────
  // Auto-generate slug from title
  document.getElementById('build-title')!.addEventListener('input', (e) => {
    const title = (e.target as HTMLInputElement).value;
    const slugEl = document.getElementById('build-slug') as HTMLInputElement;
    if (!slugEl.dataset.manualEdit) {
      slugEl.value = title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
    }
  });
  document.getElementById('build-slug')!.addEventListener('input', (e) => {
    (e.target as HTMLInputElement).dataset.manualEdit = '1';
  });

  document.getElementById('bootstrap-btn')!.addEventListener('click', async () => {
    const title     = (document.getElementById('build-title') as HTMLInputElement).value.trim();
    const slug      = (document.getElementById('build-slug') as HTMLInputElement).value.trim();
    const clientUrl = (document.getElementById('build-client-url') as HTMLInputElement).value.trim();
    if (!title || !slug) { alert('Site Name and Slug are required.'); return; }
    if (!confirm(`Launch Phase 1 build for "${title}" (${slug})?\n\nCreates:\n• GitHub: Spirit-Media-US/${slug}\n• Sanity project\n• Netlify site\n\nThis cannot be undone.`)) return;

    const btn = document.getElementById('bootstrap-btn') as HTMLButtonElement;
    btn.disabled = true; btn.textContent = 'Building…';
    document.getElementById('bootstrap-status')!.classList.remove('hidden');
    document.getElementById('bootstrap-spinner')!.classList.remove('hidden');
    document.getElementById('bootstrap-result')!.classList.add('hidden');
    document.getElementById('bootstrap-error')!.classList.add('hidden');

    try {
      const resp = await fetch('/api/tools-bootstrap', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ slug, title, client_url: clientUrl }),
      });
      const data = await resp.json();
      document.getElementById('bootstrap-spinner')!.classList.add('hidden');
      if (data.error) {
        document.getElementById('bootstrap-error')!.classList.remove('hidden');
        document.getElementById('bootstrap-error-text')!.textContent = data.error + (data.log ? '\n\n' + data.log : '');
      } else {
        document.getElementById('bootstrap-result')!.classList.remove('hidden');
        (document.getElementById('bootstrap-slug-echo') as HTMLElement).textContent = slug;
        document.getElementById('bootstrap-links')!.innerHTML = [
          { label: 'GitHub', url: data.github },
          { label: 'Netlify Preview', url: data.netlify_url },
          { label: 'Sanity Studio', url: data.sanity_studio },
        ].filter((l: any) => l.url)
         .map((l: any) => `<a href="${l.url}" target="_blank" rel="noopener noreferrer" class="block text-green-700 underline text-sm font-medium">${l.label}: ${l.url}</a>`)
         .join('');
        await loadProjects();
      }
    } catch (err: any) {
      document.getElementById('bootstrap-spinner')!.classList.add('hidden');
      document.getElementById('bootstrap-error')!.classList.remove('hidden');
      document.getElementById('bootstrap-error-text')!.textContent = err.message;
    }
    btn.disabled = false; btn.textContent = 'Initiate Build — Phase 1';
  });

  // ── 3. Pre-Launch QA ────────────────────────────────────────
  document.getElementById('qa-btn')!.addEventListener('click', async () => {
    const projectId = (document.getElementById('qa-project') as HTMLSelectElement).value;
    if (!projectId) { alert('Select a project from the pipeline first.'); return; }

    const btn = document.getElementById('qa-btn') as HTMLButtonElement;
    btn.disabled = true; btn.textContent = 'Scanning…';
    document.getElementById('qa-status')!.classList.remove('hidden');
    document.getElementById('qa-spinner')!.classList.remove('hidden');
    document.getElementById('qa-result')!.classList.add('hidden');
    document.getElementById('qa-error')!.classList.add('hidden');

    try {
      const resp = await fetch('/api/tools-prelaunch', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ project_id: projectId }),
      });
      const data = await resp.json();
      document.getElementById('qa-spinner')!.classList.add('hidden');

      if (data.error) {
        document.getElementById('qa-error')!.classList.remove('hidden');
        document.getElementById('qa-error-text')!.textContent = data.error;
      } else {
        document.getElementById('qa-result')!.classList.remove('hidden');
        const allPass = data.passed === data.total;
        const summary = document.getElementById('qa-summary')!;
        summary.className = `mb-4 p-4 rounded-lg text-sm font-semibold ${allPass ? 'bg-green-50 border border-green-200 text-green-800' : 'bg-amber-50 border border-amber-200 text-amber-800'}`;
        summary.textContent = allPass
          ? `✅ All ${data.total} scans passed — ready for human review before delivery.`
          : `⚠️ ${data.passed} of ${data.total} scans passed — fix all findings before delivery.`;

        document.getElementById('qa-scans')!.innerHTML = data.scans.map((s: any) => `
          <div class="border border-stone-200 rounded-xl overflow-hidden">
            <div class="flex items-center justify-between px-4 py-3 ${s.pass ? 'bg-green-50' : 'bg-red-50'} cursor-pointer scan-toggle">
              <span class="text-sm font-semibold ${s.pass ? 'text-green-800' : 'text-red-800'}">${s.pass ? '✅' : '❌'} ${s.name}</span>
              ${!s.pass ? `<span class="text-xs text-red-600 font-mono">${s.findings.length} finding${s.findings.length !== 1 ? 's' : ''} ▾</span>` : ''}
            </div>
            ${!s.pass && s.findings.length ? `
              <div class="px-4 py-3 bg-white hidden scan-body">
                <ul class="space-y-1">${s.findings.map((f: string) => `<li class="text-xs font-mono text-stone-700 break-all">${f}</li>`).join('')}</ul>
              </div>` : ''}
          </div>
        `).join('');

        document.querySelectorAll('.scan-toggle').forEach(h => {
          h.addEventListener('click', () => {
            const body = h.nextElementSibling;
            if (body?.classList.contains('scan-body')) body.classList.toggle('hidden');
          });
        });

        await loadProjects();
      }
    } catch (err: any) {
      document.getElementById('qa-spinner')!.classList.add('hidden');
      document.getElementById('qa-error')!.classList.remove('hidden');
      document.getElementById('qa-error-text')!.textContent = err.message;
    }
    btn.disabled = false; btn.textContent = 'Run Pre-Launch QA';
  });

  // ── Document Generator ───────────────────────────────────────
  async function loadTemplates() {
    const select = document.getElementById('template-select') as HTMLSelectElement;
    try {
      const resp = await fetch('/api/tools-templates');
      const templates = await resp.json();
      select.innerHTML = templates.map((t: any) =>
        `<option value="${t.id}">${t.name}${t.description ? ` — ${t.description}` : ''}</option>`
      ).join('');
    } catch { select.innerHTML = '<option value="">Could not load templates</option>'; }
  }

  async function loadHistory() {
    const list = document.getElementById('history-list')!;
    try {
      const resp = await fetch('/api/tools-history');
      const docs = await resp.json();
      if (!docs.length) { list.innerHTML = '<p class="text-stone-500 text-sm">No documents yet.</p>'; return; }
      list.innerHTML = docs.map((d: any) => `
        <div class="flex items-center justify-between py-3 border-b border-stone-100 last:border-0">
          <div>
            <a href="${d.url}" target="_blank" rel="noopener noreferrer"
              class="font-medium text-stone-800 hover:text-stone-600 underline">${d.name}</a>
            <span class="text-xs text-stone-400 ml-2">${d.created}</span>
          </div>
          <a href="${d.url}" target="_blank" rel="noopener noreferrer"
            class="text-xs text-stone-500 hover:text-stone-700 ml-4 shrink-0">Open →</a>
        </div>
      `).join('');
    } catch { list.innerHTML = '<p class="text-stone-500 text-sm">Could not load history.</p>'; }
  }

  document.getElementById('generate-form')!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const btn = document.getElementById('submit-btn') as HTMLButtonElement;
    const spinner = document.getElementById('status-spinner')!;
    const statusText = document.getElementById('status-text')!;
    const resultDiv = document.getElementById('status-result')!;
    const errorDiv = document.getElementById('status-error')!;
    btn.disabled = true;
    document.getElementById('status')!.classList.remove('hidden');
    spinner.classList.remove('hidden');
    resultDiv.classList.add('hidden'); errorDiv.classList.add('hidden');
    const messages = ['Reading manuscript…', 'Generating review…', 'Creating Google Doc…'];
    let msgIdx = 0; statusText.textContent = messages[0];
    const interval = setInterval(() => { msgIdx = Math.min(msgIdx + 1, messages.length - 1); statusText.textContent = messages[msgIdx]; }, 15000);
    try {
      const fd = new FormData(form);
      const resp = await fetch('/api/tools-generate', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ template_id: fd.get('template_id'), file_url: fd.get('file_url') }),
      });
      clearInterval(interval);
      const result = await resp.json();
      if (result.doc_url) {
        spinner.classList.add('hidden'); resultDiv.classList.remove('hidden');
        const rl = document.getElementById('result-link') as HTMLAnchorElement;
        rl.href = result.doc_url; rl.textContent = result.doc_name || result.doc_url;
        loadHistory();
      } else { throw new Error(result.error || 'Unknown error'); }
    } catch (err: any) {
      clearInterval(interval); spinner.classList.add('hidden'); errorDiv.classList.remove('hidden');
      document.getElementById('error-text')!.textContent = err.message;
    }
    btn.disabled = false;
  });

  // ── Blog Post Publisher ──────────────────────────────────────
  document.getElementById('blog-form')!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const btn = document.getElementById('blog-submit-btn') as HTMLButtonElement;
    const spinner = document.getElementById('blog-spinner')!;
    const statusText = document.getElementById('blog-status-text')!;
    const resultDiv = document.getElementById('blog-result')!;
    const errorDiv = document.getElementById('blog-error')!;
    btn.disabled = true;
    document.getElementById('blog-status')!.classList.remove('hidden');
    spinner.classList.remove('hidden');
    resultDiv.classList.add('hidden'); errorDiv.classList.add('hidden');
    const messages = ['Parsing content…', 'Extracting fields…', 'Publishing to Sanity…'];
    let msgIdx = 0; statusText.textContent = messages[0];
    const interval = setInterval(() => { msgIdx = Math.min(msgIdx + 1, messages.length - 1); statusText.textContent = messages[msgIdx]; }, 8000);
    try {
      const fd = new FormData(form);
      const resp = await fetch('/api/blog-post', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ content: fd.get('content'), hero_image_url: fd.get('hero_image_url') || '' }),
      });
      clearInterval(interval);
      const result = await resp.json();
      if (result.url) {
        spinner.classList.add('hidden'); resultDiv.classList.remove('hidden');
        const lu = document.getElementById('blog-live-url') as HTMLAnchorElement;
        const su = document.getElementById('blog-studio-url') as HTMLAnchorElement;
        lu.href = result.url; lu.textContent = result.url;
        su.href = result.sanity_studio; su.textContent = 'Open in Sanity Studio →';
        (form as HTMLFormElement).reset();
      } else { throw new Error(result.error || 'Unknown error'); }
    } catch (err: any) {
      clearInterval(interval); spinner.classList.add('hidden'); errorDiv.classList.remove('hidden');
      document.getElementById('blog-error-text')!.textContent = err.message;
    }
    btn.disabled = false;
  });

  // ── Init ─────────────────────────────────────────────────────
  loadProjects();
  loadTemplates();
  loadHistory();

} // end __portalInitialized guard
</script>
