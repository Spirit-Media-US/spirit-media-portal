---
import "../styles/globals.css";
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Login | Spirit Media Portal</title>
    <link rel="stylesheet" href="https://spiritmediapublishing.com/spirit-media-tokens.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800&family=Source+Sans+3:wght@400;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="login-bg">
      <div class="login-card">
        <div class="login-logo">
          <img src="https://cdn.sanity.io/images/pmowd8uo/production/dc16e3c604bd5d52de7647af46836ff418c22898-6575x656.png?w=440&h=88&fit=max&auto=format" alt="Spirit Media Publishing" class="login-logo-img" />
          <div class="logo-sub">PORTAL</div>
        </div>

        <form method="POST" action="/api/auth">
          <label for="pin">Enter PIN</label>
          <input
            id="pin"
            name="pin"
            type="password"
            inputmode="numeric"
            maxlength="6"
            placeholder="••••••"
            autocomplete="off"
            autofocus
          />
          <button type="submit">Enter Portal</button>
        </form>

        <p class="login-footer">Spirit Media Confidential</p>
      </div>
    </div>
  </body>
</html>

<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: "Source Sans 3", system-ui, sans-serif;
    background-color: #faf8f5;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .login-bg {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .login-card {
    background: #ffffff;
    border: 1px solid #ddd7cf;
    border-radius: 0.75rem;
    padding: 3rem 2.5rem;
    width: 100%;
    max-width: 400px;
    box-shadow: 0 4px 24px rgba(26,23,20,0.08);
    text-align: center;
  }

  .login-logo {
    margin-bottom: 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .login-logo-img {
    max-width: 260px;
    height: auto;
  }

  .logo-sub {
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: #9e9285;
    margin-top: 0.35rem;
  }

  label {
    display: block;
    font-size: 0.875rem;
    font-weight: 700;
    color: #574e45;
    margin-bottom: 0.5rem;
    text-align: left;
  }

  input {
    width: 100%;
    padding: 0.75rem 1rem;
    font-size: 1.25rem;
    letter-spacing: 0.3em;
    text-align: center;
    border: 1.5px solid #ddd7cf;
    border-radius: 0.375rem;
    background: #faf8f5;
    color: #1a1714;
    outline: none;
    margin-bottom: 1rem;
    transition: border-color 150ms;
  }

  input:focus {
    border-color: #c0392b;
    background: #ffffff;
  }

  button {
    width: 100%;
    padding: 0.875rem;
    background-color: #c0392b;
    color: #ffffff;
    font-family: "Source Sans 3", system-ui, sans-serif;
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border: none;
    border-radius: 0.375rem;
    cursor: pointer;
    transition: background 150ms;
  }

  button:hover { background-color: #9b2d20; }

  .login-footer {
    margin-top: 1.5rem;
    font-size: 0.75rem;
    color: #9e9285;
    letter-spacing: 0.05em;
  }
</style>
