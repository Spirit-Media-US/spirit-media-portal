            </div>
          </div>
          <div>
            <div class="preview-label" style="color:#A1A1AA;font-family:'Inter',sans-serif;">Stat</div>
            <div style="text-align:center;padding:0.75rem 1rem;">
              <div style="font-family:'Bricolage Grotesque',sans-serif;font-size:3.875rem;font-weight:800;color:#F59E0B;line-height:1;letter-spacing:-.03em;">40+</div>
              <div style="font-family:'Inter',sans-serif;font-size:0.6875rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:#A1A1AA;margin-top:3px;">Nations Reached</div>
            </div>
          </div>
        </div>
      </div>
    </section>

