          <span style="font-family:'Bricolage Grotesque',sans-serif;font-size:1rem;font-weight:800;color:#FAFAFA;">Bricolage Grotesque</span>
          <span style="font-family:'Inter',sans-serif;font-size:0.8rem;color:#A1A1AA;">Inter</span>
        </div>
      </div>
      <div class="pkg-preview" style="background:#09090B;">
        <div>
          <div class="preview-label" style="color:#A1A1AA;font-family:'Inter',sans-serif;">Typography</div>
          <div style="font-family:'Bricolage Grotesque',sans-serif;font-size:3rem;font-weight:800;color:#FAFAFA;line-height:1.0;letter-spacing:-.03em;">A <span style="color:#F59E0B;">Kingdom</span><br>Without Walls</div>
