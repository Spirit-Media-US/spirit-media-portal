          <div class="swatch-row"><div class="swatch" style="background:#3F3F46;"></div><div><span class="swatch-name" style="color:#FAFAFA;font-family:'Inter',sans-serif;">Ghost</span><span class="swatch-hex" style="color:#A1A1AA;">#3F3F46</span></div></div>
