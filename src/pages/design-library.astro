        <div style="display:flex;gap:1.625rem;flex-wrap:wrap;align-items:flex-start;">
          <div>
            <div class="preview-label" style="color:#A1A1AA;font-family:'Inter',sans-serif;">Card</div>
            <div style="background:#18181B;border:1px solid #27272A;border-top:2px solid #F59E0B;padding:1.25rem 1.5rem;border-radius:8px;max-width:280px;">
              <div style="font-family:'Inter',sans-serif;font-size:0.625rem;font-weight:600;letter-spacing:.13em;text-transform:uppercase;color:#F59E0B;margin-bottom:0.375rem;">Global Mission</div>
