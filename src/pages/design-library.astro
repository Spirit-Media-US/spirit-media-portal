        <div class="pkg-fonts">
          <span style="font-family:'DM Serif Display',serif;font-size:1.0625rem;color:#2C2C2C;">DM Serif Display</span>
          <span style="font-family:'DM Sans',sans-serif;font-size:0.8rem;color:#6B7280;">DM Sans</span>
