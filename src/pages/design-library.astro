          <div class="swatch-row"><div class="swatch" style="background:#C9A96E;"></div><div><span class="swatch-name" style="color:#2C2C2C;font-family:'DM Sans',sans-serif;">Sand</span><span class="swatch-hex" style="color:#6B7280;">#C9A96E</span></div></div>
          <div class="swatch-row"><div class="swatch" style="background:#6B7280;"></div><div><span class="swatch-name" style="color:#2C2C2C;font-family:'DM Sans',sans-serif;">Slate</span><span class="swatch-hex" style="color:#6B7280;">#6B7280</span></div></div>
