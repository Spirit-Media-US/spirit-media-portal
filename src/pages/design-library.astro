<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Design Style Library — Spirit Media Portal</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;600;700&family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Source+Sans+3:wght@400;600&family=Bricolage+Grotesque:opsz,wght@12..96,600;12..96,800&family=Inter:wght@300;400;500;600&family=DM+Serif+Display:ital@0;1&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600&family=Plus+Jakarta+Sans:wght@600;700;800&family=Syne:wght@700;800&family=Archivo+Black&family=Archivo:wght@400;500;700&family=Cormorant:ital,wght@0,300;0,400;1,300;1,400&display=swap" rel="stylesheet" />
  </head>
  <body style="margin:0;padding:0;background:#0f172a;font-family:'IBM Plex Sans',sans-serif;">

    <!-- Portal Header -->
    <header style="background:#0f172a;border-bottom:1px solid #334155;padding:1.75rem 2.5rem;">
      <div style="max-width:1280px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;">
        <div>
          <img src="https://cdn.sanity.io/images/pmowd8uo/production/dc16e3c604bd5d52de7647af46836ff418c22898-6575x656.png?w=440&h=88&fit=max&auto=format" alt="Spirit Media Publishing" style="height:2.25rem;width:auto;display:block;" />
          <p style="font-size:0.7rem;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:#94a3b8;margin-top:0.3rem;">Design Style Library</p>
        </div>
        <nav style="display:flex;gap:1.5rem;align-items:center;">
          <a href="/dashboard" style="font-family:'IBM Plex Sans',sans-serif;font-size:0.875rem;font-weight:600;color:#94a3b8;text-decoration:none;">← Dashboard</a>
          <a href="/clients" style="font-family:'IBM Plex Sans',sans-serif;font-size:0.875rem;font-weight:600;color:#94a3b8;text-decoration:none;">Client Guide</a>
        </nav>
      </div>
    </header>

    <!-- Intro Banner -->
    <div style="background:#1e293b;border-bottom:1px solid #334155;padding:1.75rem 2.5rem;">
      <div style="max-width:1280px;margin:0 auto;">
        <h1 style="font-family:'IBM Plex Sans',sans-serif;font-size:1.375rem;font-weight:700;color:#f1f5f9;margin:0 0 0.375rem;">7 Style Packages · 21 Color Palettes</h1>
        <p style="font-family:'IBM Plex Sans',sans-serif;font-size:0.9rem;color:#94a3b8;margin:0;max-width:640px;">Pre-built design systems for new Spirit Media sites. Each package includes fonts, colors, Tailwind config, and component patterns. Use with Claude: <em style="color:#d4a843;">"Build me a [Site] using Style Package: Herald."</em></p>
      </div>
    </div>

    <!-- ===== STYLE PACKAGES WRAPPER ===== -->
    <div style="background:#0a0a0a;">

    <style>
      .pkg{display:grid;grid-template-columns:300px 1fr;min-height:540px;}
      .pkg-meta{padding:40px 36px;display:flex;flex-direction:column;gap:24px;}
      .pkg-preview{padding:40px 44px;display:flex;flex-direction:column;gap:36px;border-left:1px solid;}
      .pkg-num{font-size:10px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;}
      .sw-row{display:flex;align-items:center;gap:10px;}
      .sw-dot{width:22px;height:22px;border-radius:4px;flex-shrink:0;}
      .sw-nm{font-size:12px;font-weight:600;display:block;line-height:1.3;}
      .sw-hx{font-size:10px;font-family:'Courier New',monospace;display:block;}
      .sec-lbl{font-size:10px;font-weight:600;letter-spacing:.14em;text-transform:uppercase;margin-bottom:10px;}
      .btn-row{display:flex;align-items:center;gap:10px;flex-wrap:wrap;}
      .pkg-div{height:1px;background:linear-gradient(to right,transparent,#2a2a2a,transparent);}
      .pal-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;}
      .pal-card{background:#1a1a1a;border:1px solid #2a2a2a;border-radius:9px;padding:18px 16px;}
      .pal-swatches{display:flex;gap:5px;margin-bottom:9px;}
      .pal-swatch{height:26px;flex:1;border-radius:3px;}
      .pal-hexes{display:flex;gap:4px;flex-wrap:wrap;}
      .pal-hex{font-family:'Courier New',monospace;font-size:9px;color:#555;background:#111;padding:2px 5px;border-radius:3px;}
      @media(max-width:900px){.pkg{grid-template-columns:1fr;}.pkg-preview{border-left:none;border-top:1px solid;}.pal-grid{grid-template-columns:1fr 1fr;}}
      @media(max-width:600px){.pal-grid{grid-template-columns:1fr;}}
    </style>

    <!-- TOC Pills -->
    <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:7px;padding:20px 40px;background:#0a0a0a;border-bottom:1px solid #1e1e1e;">
      <span style="font-family:'IBM Plex Sans',sans-serif;font-size:11px;font-weight:500;letter-spacing:.07em;padding:5px 12px;border-radius:99px;border:1px solid #2a2a2a;color:#888;">01 Herald · Warm Editorial</span>
      <span style="font-family:'IBM Plex Sans',sans-serif;font-size:11px;font-weight:500;letter-spacing:.07em;padding:5px 12px;border-radius:99px;border:1px solid #2a2a2a;color:#888;">02 Torch · Bold Dark</span>
      <span style="font-family:'IBM Plex Sans',sans-serif;font-size:11px;font-weight:500;letter-spacing:.07em;padding:5px 12px;border-radius:99px;border:1px solid #2a2a2a;color:#888;">03 Still Waters · Contemplative</span>
      <span style="font-family:'IBM Plex Sans',sans-serif;font-size:11px;font-weight:500;letter-spacing:.07em;padding:5px 12px;border-radius:99px;border:1px solid #2a2a2a;color:#888;">04 Cornerstone · Corporate</span>
      <span style="font-family:'IBM Plex Sans',sans-serif;font-size:11px;font-weight:500;letter-spacing:.07em;padding:5px 12px;border-radius:99px;border:1px solid #2a2a2a;color:#888;">05 Radiance · Vibrant Gradient</span>
      <span style="font-family:'IBM Plex Sans',sans-serif;font-size:11px;font-weight:500;letter-spacing:.07em;padding:5px 12px;border-radius:99px;border:1px solid #2a2a2a;color:#888;">06 Signal · Neo-Brutalist</span>
      <span style="font-family:'IBM Plex Sans',sans-serif;font-size:11px;font-weight:500;letter-spacing:.07em;padding:5px 12px;border-radius:99px;border:1px solid #2a2a2a;color:#888;">07 Summit · Luxury Minimal</span>
      <span style="font-family:'IBM Plex Sans',sans-serif;font-size:11px;font-weight:500;letter-spacing:.07em;padding:5px 12px;border-radius:99px;border:1px solid #332e00;color:#d4a843;">+ 21 Color Palettes ↓</span>
