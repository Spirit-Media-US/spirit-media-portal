        </div>
        <div>
          <div class="preview-label" style="color:#A1A1AA;font-family:'Inter',sans-serif;">Buttons</div>
          <div class="btn-row">
            <span class="prev-btn" style="background:#F59E0B;color:#09090B;font-family:'Inter',sans-serif;font-size:0.75rem;font-weight:600;letter-spacing:.06em;text-transform:uppercase;border-radius:6px;box-shadow:0 0 14px rgba(245,158,11,.2);">Join the Movement</span>
            <span class="prev-btn" style="background:transparent;color:#FAFAFA;font-family:'Inter',sans-serif;font-size:0.75rem;font-weight:600;letter-spacing:.06em;text-transform:uppercase;border-radius:6px;border:1px solid #3F3F46;">Our Mission</span>
