---
import PortalLayout from '../layouts/PortalLayout.astro';

type Role = 'Admin' | 'Web Developer' | 'GHL Developer';
type Status = 'pending' | 'inprogress' | 'done';

interface Task {
  site?: string;
  title: string;
  notes?: string;
  owner?: string;
  status: Status;
}

const admin: Task[] = [
  {
    site: 'FHB + WOY',
    title: 'Activate Cloudflare proxy',
    notes: 'SMP already proxied. FHB and WOY still need proxy toggled on in Cloudflare DNS.',
    owner: 'Claude',
    status: 'pending',
  },
  {
    site: 'All Sites',
    title: 'Set up UptimeRobot monitoring',
    notes: 'Monitor SMP, FHB, WOY, artsbyjustin. Alert Kevin on downtime.',
    owner: 'Kevin',
    status: 'pending',
  },
  {
    site: 'All Sites',
    title: 'R2 custom domain: assets.spiritmediapublishing.com',
    notes: 'Set up custom domain in Cloudflare R2 for cleaner media URLs across all sites.',
    owner: 'Claude',
    status: 'pending',
  },
  {
    site: 'Portal',
    title: 'Preview environment for dev branch',
    notes: 'Option 2 (Hetzner): Run npm run dev on server, expose via preview.spiritmediapublishing.com on port 4001. nginx config already exists with SSL.',
    owner: 'Claude',
    status: 'pending',
  },
  {
    site: 'Portal',
    title: 'Add .gitignore to portal repo',
    notes: 'Portal is committing .netlify/ and dist/ build folders to git — noisy and wasteful.',
    owner: 'Claude',
    status: 'pending',
  },
  {
    site: 'SMP',
    title: 'DMARC upgrade to p=quarantine',
    notes: 'Wait 1 week clean after current p=none, then upgrade. Kevin to confirm timing.',
    owner: 'Kevin + Claude',
    status: 'pending',
  },

  // ── ARTS BY JUSTIN ──────────────────────────────────────────────
  {
    site: 'Arts By Justin',
    title: 'Connect artsbyjustin.com custom domain in Netlify',
    notes: 'Then activate Cloudflare proxy.',
    owner: 'Claude',
    status: 'pending',
  },
  {
    site: 'Arts By Justin',
    title: 'Replace R2 image placeholders with real artwork',
    notes: 'Justin shares Google Drive folder → Kevin downloads → drag to R2 bucket → update URLs in code.',
    owner: 'Kevin',
    status: 'pending',
  },
  {
    site: 'Arts By Justin',
    title: 'Replace placeholder divs with GHL form embed codes',
    notes: 'Kevin to provide GHL embed codes for each form location.',
    owner: 'Kevin + Claude',
    status: 'pending',
  },

  // ── SPIRIT MEDIA PUBLISHING ─────────────────────────────────────
  {
    site: "SMP",
    title: "Verify OG tags at opengraph.xyz",
    notes: "Check homepage and a blog post at opengraph.xyz to confirm title, description, and image render correctly for social sharing.",
    owner: "Kevin",
    status: "pending",
  },
  {
    site: "SMP",
    title: "Switch to cookie-free analytics (Fathom or Plausible)",
    notes: "GA4 via GTM causes Lighthouse Best Practices score of 77. Fathom or Plausible raises it to ~95 and removes cookie consent requirement.",
    owner: "Kevin",
    status: "pending",
  },
  {
    site: "SMP",
    title: "Populate teamMember, testimonial, pressRelease in Sanity",
    notes: "All three have 0 documents. Add team bios (Kevin + Shelly at minimum), author testimonials, and press mentions at spiritmediapublishing.sanity.studio.",
    owner: "Kevin",
    status: "pending",
  },
  {
    site: 'SMP',
    title: 'Bookstore: research missing ASINs and fill in format badges',
    notes: 'Format badges and stats counter are working. Many titles still missing format data. Kevin noted 300+ titles total.',
    owner: 'Kevin + Claude',
    status: 'pending',
  },

  // ── THE KOHLER GROUP ────────────────────────────────────────────
  {
    site: 'The Kohler Group',
    title: 'Individual and marriage intensive video pages',
    notes: 'Kevin waiting on YouTube URLs from client. Will update individual.astro and marriage.astro once received.',
    owner: 'Kevin',
    status: 'pending',
  },
  {
    site: 'The Kohler Group',
    title: 'Connect custom domain (thekohlergroup.net)',
    notes: 'Currently live at the-kohler-group.netlify.app only.',
    owner: 'Claude',
    status: 'pending',
  },

  // ── PORTAL ──────────────────────────────────────────────────────
  {
    site: 'Portal',
    title: 'Make Task Log editable without a code push',
    notes: 'Options: Netlify Blobs or Sanity. Netlify Blobs recommended for now.',
    status: 'pending',
  },
  {
    title: 'Complete ACNotifications workflow in GHL',
    notes: 'Finish Email step body with webhook payload fields, save, publish.',
    status: 'pending',
  },
  {
    title: 'Develop Scale Plan',
    status: 'pending',
  },
  {
    title: 'Script for manuscript review',
    status: 'pending',
  },
  {
    title: 'Script for manuscript evaluation',
    status: 'pending',
  },
  {
    title: 'Publishing Checklist Portal',
    status: 'pending',
  },
  {
    title: "Believer's Library mobile app launch",
    notes: 'Target: 2026.',
    status: 'pending',
  },
];

const webDev: Task[] = [
  {
    title: 'SMP Bookstore — research missing ASINs and fill in format badges',
    notes: 'Format badges and stats counter working. Many titles still missing format data. 300+ titles total.',
    status: 'pending',
  },
  {
    title: 'Portal — NotebookLM explainer videos for /clients page',
    notes: 'Kevin to record or provide videos.',
    status: 'pending',
  },
  {
    title: 'Portal — feature request flow for non-technical team',
    notes: 'Add GHL form on /clients page for Jim, Sheila, Adam to submit requests.',
    status: 'pending',
  },
  {
    title: 'Playbook — add standard page structure',
    notes: 'Home, About, Services/Work, Blog/Articles, Contact, Privacy Policy.',
    status: 'pending',
  },
  {
    title: 'Playbook — add backup / recovery process',
    notes: 'GitHub = source code, R2 = media backup, Netlify deploy history = rollback.',
    status: 'pending',
  },
  {
    title: 'Playbook — add SEO standards',
    notes: 'H1 once per page, alt tags required, structured data, OpenGraph tags.',
    status: 'pending',
  },
  {
    title: 'Script for website checklist',
    status: 'pending',
  },
  {
    title: 'Script for website extraction',
    status: 'pending',
  },
  {
    title: 'Script for website migration',
    status: 'pending',
  },
];

const ghlDev: Task[] = [
  {
    title: 'Angel Writing Onboarding',
    status: 'pending',
  },
  {
    title: 'Prove Claude empowered GHL',
    status: 'pending',
  },
  {
    title: 'Landing Page Onboarding',
    status: 'pending',
  },
  {
    title: 'Website Builder Onboarding',
    status: 'pending',
  },
];

const sections: { label: string; role: Role; tasks: Task[] }[] = [
  { label: 'Admin', role: 'Admin', tasks: admin },
  { label: 'Web Developer', role: 'Web Developer', tasks: webDev },
  { label: 'GHL Developer', role: 'GHL Developer', tasks: ghlDev },
];

const roleColor: Record<Role, string> = {
  'Admin':          'background:#eff6ff;color:#1d4ed8;border:1px solid #bfdbfe;',
  'Web Developer':  'background:#f0fdf4;color:#166534;border:1px solid #bbf7d0;',
  'GHL Developer':  'background:#fdf2f8;color:#9d174d;border:1px solid #fbcfe8;',
};
const roleBg: Record<Role, string> = {
  'Admin':          'background:#eff6ff;border-color:#bfdbfe;',
  'Web Developer':  'background:#f0fdf4;border-color:#bbf7d0;',
  'GHL Developer':  'background:#fdf2f8;border-color:#fbcfe8;',
};
const roleIcon: Record<Role, string> = {
  'Admin':          '\uD83D\uDC64',
  'Web Developer':  '\uD83D\uDEE0\uFE0F',
  'GHL Developer':  '\uD83D\uDE80',
};
---

<PortalLayout title="Task Log">
  <div class="max-w-4xl">
    <h1 class="text-4xl font-bold mb-1">Task Log</h1>
    <p class="text-stone-500 mb-2">All pending work sorted by role</p>
    <div class="flex flex-wrap gap-3 mb-8 text-xs">
      <span style={roleColor['Admin']} class="px-2 py-1 rounded font-semibold">{roleIcon['Admin']} Admin &mdash; {admin.filter(t => t.status === 'pending').length} tasks</span>
      <span style={roleColor['Web Developer']} class="px-2 py-1 rounded font-semibold">{roleIcon['Web Developer']} Web Developer &mdash; {webDev.filter(t => t.status === 'pending').length} tasks</span>
      <span style={roleColor['GHL Developer']} class="px-2 py-1 rounded font-semibold">{roleIcon['GHL Developer']} GHL Developer &mdash; {ghlDev.filter(t => t.status === 'pending').length} tasks</span>
    </div>

    {sections.map(section => {
      const pending = section.tasks.filter(t => t.status === 'pending');
      if (pending.length === 0) return null;
      return (
        <div class="mb-8">
          <h2 class="text-xs font-bold uppercase tracking-widest text-stone-400 mb-3">{roleIcon[section.role]} {section.label} <span class="text-stone-300">({pending.length})</span></h2>
          <div class="space-y-2">
            {pending.map(task => (
              <div class="border rounded-lg px-5 py-4" style={roleBg[section.role]}>
                <p class="text-sm font-semibold text-stone-800">{task.title}</p>
                {task.notes && <p class="text-xs text-stone-500 mt-1">{task.notes}</p>}
              </div>
            ))}
          </div>
        </div>
      );
    })}
  </div>
</PortalLayout>
