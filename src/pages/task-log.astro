---
import PortalLayout from '../layouts/PortalLayout.astro';

type Role = 'Admin' | 'Web Developer' | 'GHL Developer';
type Status = 'pending' | 'inprogress' | 'done';

interface Task {
  title: string;
  notes?: string;
  status: Status;
}

const admin: Task[] = [
  {
    title: 'Make Task Log editable without a code push',
    notes: 'Options: Netlify Blobs or Sanity. Netlify Blobs recommended for now.',
    status: 'pending',
  },
  {
    title: 'Complete ACNotifications workflow in GHL',
    notes: 'Finish Email step body with webhook payload fields, save, publish.',
    status: 'pending',
  },
  {
    title: 'Develop Scale Plan',
    status: 'pending',
  },
  {
    title: 'Script for manuscript review',
    status: 'pending',
  },
  {
    title: 'Script for manuscript evaluation',
    status: 'pending',
  },
  {
    title: 'Publishing Checklist Portal',
    status: 'pending',
  },
  {
    title: "Believer's Library mobile app launch",
    notes: 'Target: 2026.',
    status: 'pending',
  },
];

const webDev: Task[] = [
  {
    title: 'SMP Bookstore — research missing ASINs and fill in format badges',
    notes: 'Format badges and stats counter working. Many titles still missing format data. 300+ titles total.',
    status: 'pending',
  },
  {
    title: 'Portal — NotebookLM explainer videos for /clients page',
    notes: 'Kevin to record or provide videos.',
    status: 'pending',
  },
  {
    title: 'Portal — feature request flow for non-technical team',
    notes: 'Add GHL form on /clients page for Jim, Sheila, Adam to submit requests.',
    status: 'pending',
  },
  {
    title: 'Playbook — add standard page structure',
    notes: 'Home, About, Services/Work, Blog/Articles, Contact, Privacy Policy.',
    status: 'pending',
  },
  {
    title: 'Playbook — add backup / recovery process',
    notes: 'GitHub = source code, R2 = media backup, Netlify deploy history = rollback.',
    status: 'pending',
  },
  {
    title: 'Playbook — add SEO standards',
    notes: 'H1 once per page, alt tags required, structured data, OpenGraph tags.',
    status: 'pending',
  },
  {
    title: 'Script for website checklist',
    status: 'pending',
  },
  {
    title: 'Script for website extraction',
    status: 'pending',
  },
  {
    title: 'Script for website migration',
    status: 'pending',
  },
];

const ghlDev: Task[] = [
  {
    title: 'Angel Writing Onboarding',
    status: 'pending',
  },
  {
    title: 'Prove Claude empowered GHL',
    status: 'pending',
  },
  {
    title: 'Landing Page Onboarding',
    status: 'pending',
  },
  {
    title: 'Website Builder Onboarding',
    status: 'pending',
  },
];

const sections: { label: string; role: Role; tasks: Task[] }[] = [
  { label: 'Admin', role: 'Admin', tasks: admin },
  { label: 'Web Developer', role: 'Web Developer', tasks: webDev },
  { label: 'GHL Developer', role: 'GHL Developer', tasks: ghlDev },
];

const roleColor: Record<Role, string> = {
  'Admin':          'background:#eff6ff;color:#1d4ed8;border:1px solid #bfdbfe;',
  'Web Developer':  'background:#f0fdf4;color:#166534;border:1px solid #bbf7d0;',
  'GHL Developer':  'background:#fdf2f8;color:#9d174d;border:1px solid #fbcfe8;',
};
const roleBg: Record<Role, string> = {
  'Admin':          'background:#eff6ff;border-color:#bfdbfe;',
  'Web Developer':  'background:#f0fdf4;border-color:#bbf7d0;',
  'GHL Developer':  'background:#fdf2f8;border-color:#fbcfe8;',
};
const roleIcon: Record<Role, string> = {
  'Admin':          '\uD83D\uDC64',
  'Web Developer':  '\uD83D\uDEE0\uFE0F',
  'GHL Developer':  '\uD83D\uDE80',
};
---

<PortalLayout title="Task Log">
  <div class="max-w-4xl">
    <h1 class="text-4xl font-bold mb-1">Task Log</h1>
    <p class="text-stone-500 mb-2">All pending work sorted by role</p>
    <div class="flex flex-wrap gap-3 mb-8 text-xs">
      <span style={roleColor['Admin']} class="px-2 py-1 rounded font-semibold">{roleIcon['Admin']} Admin &mdash; {admin.filter(t => t.status === 'pending').length} tasks</span>
      <span style={roleColor['Web Developer']} class="px-2 py-1 rounded font-semibold">{roleIcon['Web Developer']} Web Developer &mdash; {webDev.filter(t => t.status === 'pending').length} tasks</span>
      <span style={roleColor['GHL Developer']} class="px-2 py-1 rounded font-semibold">{roleIcon['GHL Developer']} GHL Developer &mdash; {ghlDev.filter(t => t.status === 'pending').length} tasks</span>
    </div>

    {sections.map(section => {
      const pending = section.tasks.filter(t => t.status === 'pending');
      if (pending.length === 0) return null;
      return (
        <div class="mb-8">
          <h2 class="text-xs font-bold uppercase tracking-widest text-stone-400 mb-3">{roleIcon[section.role]} {section.label} <span class="text-stone-300">({pending.length})</span></h2>
          <div class="space-y-2">
            {pending.map(task => (
              <div class="border rounded-lg px-5 py-4" style={roleBg[section.role]}>
                <p class="text-sm font-semibold text-stone-800">{task.title}</p>
                {task.notes && <p class="text-xs text-stone-500 mt-1">{task.notes}</p>}
              </div>
            ))}
          </div>
        </div>
      );
    })}
  </div>
</PortalLayout>
